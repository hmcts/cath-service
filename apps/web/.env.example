# Server Configuration
PORT=8080
BASE_URL=https://localhost:8080

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-this-in-production

# Redis Configuration
REDIS_URL=redis://localhost:6380

# CFT IDAM Configuration
# Set ENABLE_CFT_IDAM=true in development to enable CFT IDAM (always enabled in production)
ENABLE_CFT_IDAM=true
CFT_IDAM_URL=https://idam-web-public.aat.platform.hmcts.net
# CFT_IDAM_CLIENT_SECRET is loaded from Key Vault (pip-ss-kv)

# SSO Configuration (Azure AD)
# These secrets are loaded from Azure Key Vault automatically:
# - Local development: pip-ss-kv (requires `az login`)
# - Deployed environments: via properties volume (automatic)
#
# Secrets loaded from Key Vault (pip-ss-kv):
# - SSO_CLIENT_ID
# - SSO_CLIENT_SECRET
# - SSO_IDENTITY_METADATA
# - SSO_SYSTEM_ADMIN_GROUP_ID
# - SSO_INTERNAL_ADMIN_CTSC_GROUP_ID
# - SSO_INTERNAL_ADMIN_LOCAL_GROUP_ID
# - CFT_IDAM_CLIENT_SECRET
SSO_ALLOW_HTTP_REDIRECT=false

# Azure B2C Configuration (for CaTH verified users)
# B2C_CLIENT_ID and B2C_CLIENT_SECRET are loaded from Azure Key Vault.
# Non-secret config must be set here for local development.
ENABLE_B2C=true
B2C_CUSTOM_DOMAIN=
B2C_CUSTOM_DOMAIN_PATH=

# Application Insights (Optional - loaded from Key Vault in deployed environments)
# APPLICATION_INSIGHTS_CONNECTION_STRING is loaded from Key Vault (cath)

# GOV.UK Notify Configuration
# GOVUK_NOTIFY_API_KEY is loaded from Key Vault (cath)
# Template IDs are plain environment variables (not secrets)
GOVUK_NOTIFY_TEMPLATE_ID_SUBSCRIPTION=5b5c31d0-27a3-466b-b750-bd1a858cd50f
GOVUK_NOTIFY_TEMPLATE_ID_SUBSCRIPTION_PDF_AND_SUMMARY=ebc08910-5dd5-44c5-b3fc-72f90935f858
GOVUK_NOTIFY_TEMPLATE_ID_SUBSCRIPTION_SUMMARY_ONLY=bf0802f9-3199-4774-a0c1-f9cb1755ff8f
GOVUK_NOTIFY_TEMPLATE_ID_MEDIA_APPROVAL=91d93e44-0ad8-4782-8ef0-fb1cad0c641f
GOVUK_NOTIFY_TEMPLATE_ID_MEDIA_REJECTION=838be14a-1ca2-408f-a4bc-a8b4d3c7d54d

# Service URL for generating links in notifications
CATH_SERVICE_URL=https://www.court-tribunal-hearings.service.gov.uk
