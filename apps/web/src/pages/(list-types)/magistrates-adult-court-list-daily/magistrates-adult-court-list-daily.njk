{% extends "layouts/base-template.njk" %}

{% block head %}
  {{ super() }}
  <style>
    .govuk-accordion__controls {
      text-align: right;
    }
    .govuk-accordion__section-content {
      overflow: auto hidden;
    }
    .govuk-table {
      overflow: auto hidden;
    }
  </style>
{% endblock %}

{% block page_content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">

    <h2 class="govuk-heading-l">{{ t.pageTitle }} {{ header.locationName }}</h2>

    <p class="govuk-body">
      <a href="{{ t.factLinkUrl }}" class="govuk-link">{{ t.factLinkText }}</a> {{ t.factAdditionalText }}
    </p>

    <p class="govuk-body">
      {% for line in header.addressLines %}
        {{ line }}{% if not loop.last %}<br>{% endif %}
      {% endfor %}
    </p>

    <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ t.listFor }} {{ header.contentDate }}</p>
    <p class="govuk-body">{{ t.lastUpdated }} {{ header.lastUpdated }}</p>

    <details class="govuk-details" data-module="govuk-details" open>
      <summary class="govuk-details__summary">
        <span class="govuk-details__summary-text">
          {{ t.importantInformation }}
        </span>
      </summary>
      <div class="govuk-details__text">
        <p class="govuk-body">{{ t.openJusticeIntro }}</p>
        <p class="govuk-body">{{ t.openJusticeDecision }}</p>
        <p class="govuk-body">{{ t.openJusticePrivate }}</p>
        <p class="govuk-body">
          {{ t.openJusticeMoreInfo }}
          <a href="{{ t.openJusticeLink }}" class="govuk-link" target="_blank" rel="noopener noreferrer">
            {{ t.openJusticeLinkText }}
          </a>.
        </p>
      </div>
    </details>

    <div class="govuk-form-group govuk-!-margin-top-6">
      <h2 class="govuk-heading-m">{{ t.searchCases }}</h2>
      <input class="govuk-input govuk-!-width-one-half" id="case-search-input" name="search" type="text">
    </div>

    <div id="court-lists-container">
    {% for courtList in listData.courtLists %}
      {% set courtHouse = courtList.courtHouse %}

      <div class="govuk-accordion" data-module="govuk-accordion">
        {% for courtRoom in courtHouse.courtRoom %}
          {% for session in courtRoom.session %}
            <div class="govuk-accordion__section govuk-accordion__section--expanded">
              <div class="govuk-accordion__section-header">
                <h2 class="govuk-accordion__section-heading">
                  <span class="govuk-accordion__section-button">
                    {{ courtRoom.courtRoomName }}{% if session.formattedJudiciaries | length %}: {{ session.formattedJudiciaries }}{% endif %}
                  </span>
                </h2>
              </div>
              <div class="govuk-accordion__section-content">
                {% set hasHearings = false %}
                {% for sitting in session.sittings %}
                  {% if sitting.hearing | length %}
                    {% set hasHearings = true %}
                  {% endif %}
                {% endfor %}

                {% if not hasHearings %}
                  <p class="govuk-body">{{ t.noHearings }}</p>
                {% else %}
                  <table class="govuk-table" data-module="moj-sortable-table">
                    <thead class="govuk-table__head">
                      <tr class="govuk-table__row">
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.blockStart }}</th>
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.defendantName }}</th>
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.dateOfBirth }}</th>
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.address }}</th>
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.age }}</th>
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.caseNumber }}</th>
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.offenceCode }}</th>
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.offenceTitle }}</th>
                        <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.offenceSummary }}</th>
                      </tr>
                    </thead>
                    <tbody class="govuk-table__body">
                      {% for sitting in session.sittings %}
                        {% for hearing in sitting.hearing %}
                          {% for case in hearing.case %}
                            {% for defendant in case.defendants %}
                              {% if defendant.offences | length %}
                                {% for offence in defendant.offences %}
                                  <tr class="govuk-table__row">
                                    <td class="govuk-table__cell">{{ sitting.blockStart }}</td>
                                    <td class="govuk-table__cell">{{ defendant.name }}</td>
                                    <td class="govuk-table__cell">{{ defendant.dateOfBirth }}</td>
                                    <td class="govuk-table__cell">{{ defendant.address }}</td>
                                    <td class="govuk-table__cell">{{ defendant.age }}</td>
                                    <td class="govuk-table__cell">{{ case.caseNumber }}</td>
                                    <td class="govuk-table__cell">{{ offence.offenceCode }}</td>
                                    <td class="govuk-table__cell">{{ offence.offenceTitle }}</td>
                                    <td class="govuk-table__cell">{{ offence.offenceSummary }}</td>
                                  </tr>
                                {% endfor %}
                              {% else %}
                                <tr class="govuk-table__row">
                                  <td class="govuk-table__cell">{{ sitting.blockStart }}</td>
                                  <td class="govuk-table__cell">{{ defendant.name }}</td>
                                  <td class="govuk-table__cell">{{ defendant.dateOfBirth }}</td>
                                  <td class="govuk-table__cell">{{ defendant.address }}</td>
                                  <td class="govuk-table__cell">{{ defendant.age }}</td>
                                  <td class="govuk-table__cell">{{ case.caseNumber }}</td>
                                  <td class="govuk-table__cell"></td>
                                  <td class="govuk-table__cell"></td>
                                  <td class="govuk-table__cell"></td>
                                </tr>
                              {% endif %}
                            {% endfor %}
                            {% if case.formattedReportingRestriction | length %}
                              <tr class="govuk-table__row">
                                <td class="govuk-table__cell" colspan="9">
                                  <strong>{{ t.reportingRestrictions }}:</strong> {{ t.reportingRestrictionWarning }}
                                </td>
                              </tr>
                            {% endif %}
                          {% endfor %}
                        {% endfor %}
                      {% endfor %}
                    </tbody>
                  </table>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    {% endfor %}
    </div>

    <p class="govuk-body" style="font-size: 14px;">
      {{ t.dataSource }}: {{ dataSource }}
    </p>

    <p class="govuk-body">
      <a href="#top" class="govuk-link">{{ t.linkToTop }}</a>
    </p>

  </div>
</div>
{% endblock %}
