{% extends "layouts/base-template.njk" %}

{% block head %}
  {{ super() }}
  <style>
    .govuk-table {
      overflow: auto hidden;
    }
  </style>
{% endblock %}

{% block page_content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">

    <h1 class="govuk-heading-l">{{ t.listName }}</h1>

    <div class="govuk-!-margin-bottom-6">
      <p class="govuk-body">{{ t.staticAddress.line1 }}</p>
      <p class="govuk-body">{{ t.staticAddress.line2 }}</p>
      <p class="govuk-body">{{ t.staticAddress.line3 }}</p>
      <p class="govuk-body">{{ t.staticAddress.line4 }}</p>
    </div>

    <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ t.listDate }}{{ header.contentDate }}</p>
    <p class="govuk-body">{{ t.lastUpdated }}{{ header.lastUpdatedDate }} {{ t.at }}{{ header.lastUpdatedTime }}</p>

    <details class="govuk-details" data-module="govuk-details" open>
      <summary class="govuk-details__summary">
        <span class="govuk-details__summary-text">
          {{ t.importantInformationHeading }}
        </span>
      </summary>
      <div class="govuk-details__text">
        <p class="govuk-body">{{ t.openJusticeMessage }}</p>
        <p class="govuk-body">{{ t.joinHearingMessage }}</p>
        <p class="govuk-body">
          {{ t.observeHearingText }}
          <a href="{{ t.observeHearingLink }}" class="govuk-link" target="_blank" rel="noopener noreferrer">
            {{ t.observeHearingLink }}
          </a>
        </p>
      </div>
    </details>

    <div class="govuk-form-group govuk-!-margin-top-6">
      <h2 class="govuk-heading-m">{{ t.searchCases || "Search cases" }}</h2>
      <input class="govuk-input govuk-!-width-one-half" id="case-search-input" name="search" type="text">
    </div>

    <div id="hearing-list-container">
      {% if hearings and hearings.length > 0 %}
        <table class="govuk-table" data-module="moj-sortable-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.fields.appellant }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.fields.appealReferenceNumber }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.fields.caseType }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.fields.hearingType }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.fields.hearingTime }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.fields.additionalInformation }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for hearing in hearings %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ hearing.appellant }}</td>
                <td class="govuk-table__cell">{{ hearing.appealReferenceNumber }}</td>
                <td class="govuk-table__cell">{{ hearing.caseType }}</td>
                <td class="govuk-table__cell">{{ hearing.hearingType }}</td>
                <td class="govuk-table__cell">{{ hearing.hearingTime }}</td>
                <td class="govuk-table__cell">{{ hearing.additionalInformation }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="govuk-body">{{ t.noHearings || "No hearings scheduled" }}</p>
      {% endif %}
    </div>

    <div class="govuk-!-margin-top-6">
      <p class="govuk-body govuk-!-font-size-14">{{ t.dataSource }}{{ dataSource }}</p>
      <p class="govuk-body govuk-!-margin-top-4">{{ t.bottomLegal1 }}</p>
      <p class="govuk-body">{{ t.bottomLegal2 }}</p>
      <p class="govuk-body govuk-!-margin-top-4">{{ t.thanks }}</p>
    </div>

    <p class="govuk-body govuk-!-margin-top-6">
      <a href="#top" class="govuk-link">{{ t.linkToTop || "Back to top" }}</a>
    </p>

  </div>
</div>

<script>
  (function() {
    const searchInput = document.getElementById('case-search-input');
    const tableRows = document.querySelectorAll('#hearing-list-container tbody tr');

    if (searchInput && tableRows.length > 0) {
      searchInput.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();

        tableRows.forEach(function(row) {
          const text = row.textContent.toLowerCase();
          if (text.includes(searchTerm)) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }
  })();
</script>
{% endblock %}
