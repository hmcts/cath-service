{% extends "layouts/base-template.njk" %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block head %}
  {{ super() }}
  <style>
    .govuk-table {
      overflow: auto hidden;
    }
  </style>
{% endblock %}

{% block page_content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">

    <h1 class="govuk-heading-l">{{ t.listName }}</h1>

    <p class="govuk-body">
      <a href="{{ t.factLink }}" class="govuk-link" target="_blank" rel="noopener noreferrer">{{ t.factLinkText1 }}</a>{{ t.factLinkText2 }}
    </p>

    <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ t.listDate }}{{ header.contentDate }}</p>
    <p class="govuk-body">{{ t.lastUpdated }}{{ header.lastUpdatedDate }} {{ t.at }}{{ header.lastUpdatedTime }}</p>

    {{ govukDetails({
      summaryText: t.importantInformationHeading,
      html: '<p class="govuk-body">' + t.importantInformationLine1 + '</p>
             <p class="govuk-body">' + t.importantInformationLine2 + '</p>
             <p class="govuk-body">' + t.importantInformationLine3 + '</p>
             <p class="govuk-body">' + t.importantInformationLine4 + '</p>
             <p class="govuk-body">' + t.importantInformationLine5 + '</p>',
      open: true
    }) }}

    <div class="govuk-form-group govuk-!-margin-top-6">
      <h2 class="govuk-heading-m">{{ t.searchCasesTitle }}</h2>
      <label class="govuk-label" for="case-search-input">
        {{ t.searchCasesLabel }}
      </label>
      <input class="govuk-input govuk-!-width-one-half" id="case-search-input" name="search" type="text">
    </div>

    <div id="hearings-container" class="govuk-!-margin-top-6">
      {% if hearings.length > 0 %}
        <table class="govuk-table" data-module="moj-sortable-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.tableHeaders.time }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.tableHeaders.caseReferenceNumber }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.tableHeaders.respondent }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.tableHeaders.hearingType }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.tableHeaders.venue }}</th>
              <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.tableHeaders.timeEstimate }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for hearing in hearings %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ hearing.time }}</td>
                <td class="govuk-table__cell">{{ hearing.caseReferenceNumber }}</td>
                <td class="govuk-table__cell">{{ hearing.respondent }}</td>
                <td class="govuk-table__cell">{{ hearing.hearingType }}</td>
                <td class="govuk-table__cell">{{ hearing.venue }}</td>
                <td class="govuk-table__cell">{{ hearing.timeEstimate }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="govuk-body">{{ t.noHearingsMessage }}</p>
      {% endif %}
    </div>

    <p class="govuk-body govuk-body-s govuk-!-margin-top-6">
      {{ t.dataSource }}{{ dataSource }}
    </p>

    <p class="govuk-body">
      <a href="#top" class="govuk-link">{{ t.backToTop }}</a>
    </p>

  </div>
</div>

<script>
  // Simple client-side search functionality
  (function() {
    const searchInput = document.getElementById('case-search-input');
    const tableRows = document.querySelectorAll('#hearings-container tbody tr');

    if (searchInput && tableRows.length > 0) {
      searchInput.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();

        tableRows.forEach(function(row) {
          const text = row.textContent.toLowerCase();
          if (text.includes(searchTerm)) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }
  })();
</script>
{% endblock %}
