{% extends "layouts/base-template.njk" %}

{% block head %}
  {{ super() }}
  <style>
    .govuk-accordion__controls {
      text-align: right;
    }
    .no-wrap {
      white-space: nowrap;
    }
    .govuk-accordion__section-content {
      overflow: auto hidden;
    }
    .govuk-table {
      overflow: auto hidden;
    }
    .restriction-list-section {
      background-color: #f3f2f1;
      padding: 20px;
      margin-bottom: 20px;
    }
    .align-warning-icon {
      top: 0;
    }
    .site-header {
      margin-bottom: 20px;
    }
    .site-address {
      margin-bottom: 5px;
    }
    .overflow-table {
      overflow: auto hidden;
      display: block;
    }
  </style>
{% endblock %}

{% block page_content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">

    <div class="parent-box">
      <h1 id="page-heading" class="govuk-heading-l">{{ t.pageTitle }} {{ header.locationName }}</h1>
    </div>

    <p class="govuk-body">
      <a href="{{ t.factLinkUrl }}" class="govuk-link">{{ t.factLinkText }}</a> {{ t.factAdditionalText }}
    </p>

    <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ t.listFor }} {{ header.contentDate }}</p>
    <p class="govuk-body">{{ t.lastUpdated }} {{ header.lastUpdated }}</p>

    {% if header.version | length %}
      <p class="govuk-body">{{ t.version }} {{ header.version }}</p>
    {% endif %}

    <p class="govuk-body">
      {% for line in header.addressLines %}
        {{ line }}{% if not loop.last %}<br>{% endif %}
      {% endfor %}
    </p>

    <div class="govuk-grid restriction-list-section govuk-!-margin-bottom-5">
      <div class="govuk-body">
        <h3 class="govuk-heading-m">{{ t.reportingRestrictionsTitle }}</h3>
        <p class="govuk-body">{{ t.reportingRestrictionsBodyIntro }}</p>
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon align-warning-icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-warning-text__assistive">Warning</span>
            {{ t.reportingRestrictionsWarning }}
          </strong>
        </div>
        <p class="govuk-body">{{ t.reportingRestrictionsBodySpecific }}</p>
        <p class="govuk-body">{{ t.reportingRestrictionsBodyHowever }}</p>
        <p class="govuk-body">{{ t.reportingRestrictionsBodyContact }}</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>{{ t.reportingRestrictionsContactCourt }}</li>
          <li>{{ t.reportingRestrictionsContactHmcts }}</li>
        </ul>
      </div>
    </div>

    <div class="govuk-form-group govuk-!-margin-top-6">
      <h2 class="govuk-heading-m">{{ t.searchCases }}</h2>
      <input class="govuk-input govuk-!-width-one-half" id="case-search-input" name="search" type="text">
    </div>

    <div id="court-lists-container">
      <div class="govuk-accordion" data-module="govuk-accordion" id="accordion-default">
        {% for dayGroup in groupedListData %}
          <div class="govuk-accordion__section govuk-accordion__section--expanded">
            <div class="govuk-accordion__section-header">
              <h2 class="govuk-accordion__section-heading">
                <span class="govuk-accordion__section-button">
                  {{ t.day }}: {{ dayGroup.day }}
                </span>
              </h2>
            </div>
            <div class="govuk-accordion__section-content">
              {% for sitting in dayGroup.sittings %}
                <div class="govuk-!-margin-bottom-6" tabindex="0" aria-label="{{ t.courtHouseDetails }}">
                  <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
                    {% if sitting.formattedJudiciaries | length %}
                      {{ t.court }} {{ sitting.courtRoomName }}: {{ sitting.formattedJudiciaries }}
                    {% else %}
                      {{ t.court }} {{ sitting.courtRoomName }}
                    {% endif %}
                  </h3>
                  <p class="govuk-body govuk-!-font-weight-bold">{{ t.sittingAt }} {{ sitting.time }}</p>
                  <table class="govuk-table overflow-table" data-module="moj-sortable-table">
                    <thead class="govuk-table__head">
                      <tr class="govuk-table__row">
                        <th scope="col" class="govuk-table__header no-wrap" aria-sort="none">{{ t.caseNumber }}</th>
                        <th scope="col" class="govuk-table__header no-wrap" aria-sort="none">{{ t.defendant }}</th>
                        <th scope="col" class="govuk-table__header no-wrap" aria-sort="none">{{ t.hearingType }}</th>
                        <th scope="col" class="govuk-table__header no-wrap" aria-sort="none">{{ t.representative }}</th>
                        <th scope="col" class="govuk-table__header no-wrap" aria-sort="none">{{ t.prosecutingAuthority }}</th>
                        <th scope="col" class="govuk-table__header no-wrap" aria-sort="none">{{ t.listingNotes }}</th>
                      </tr>
                    </thead>
                    <tbody class="govuk-table__body">
                      {% for hearing in sitting.hearing %}
                        {% for case in hearing.case %}
                          <tr class="govuk-table__row">
                            <td class="govuk-table__cell no-wrap">{{ case.caseNumber }}</td>
                            <td class="govuk-table__cell">{{ case.defendants }}</td>
                            <td class="govuk-table__cell no-wrap">{{ hearing.displayHearingType }}</td>
                            <td class="govuk-table__cell">{{ case.representative }}</td>
                            <td class="govuk-table__cell no-wrap">{{ case.prosecutingAuthority }}</td>
                            <td class="govuk-table__cell">{{ case.listingNotes }}</td>
                          </tr>
                          {% if case.formattedReportingRestriction | length %}
                            <tr class="govuk-table__row">
                              <td class="govuk-table__cell" colspan="6">
                                <strong>{{ t.reportingRestrictions }}:</strong> {{ case.formattedReportingRestriction }}
                              </td>
                            </tr>
                          {% endif %}
                        {% endfor %}
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <p class="govuk-body-s govuk-!-margin-top-6">
      {{ t.dataSource }}: {{ dataSource }}
    </p>

    <div class="back-to-top">
      <a href="#top" class="govuk-link">{{ t.backToTop }}</a>
    </div>

  </div>
</div>
{% endblock %}
