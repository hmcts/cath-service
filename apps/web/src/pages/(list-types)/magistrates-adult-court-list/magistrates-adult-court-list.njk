{% extends "layouts/base-template.njk" %}

{% block page_content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">

    <h1 class="govuk-heading-l">{{ t.pageTitle }} {{ header.locationName }}</h1>

    <p class="govuk-body">
      <a href="{{ t.factLinkUrl }}" class="govuk-link">{{ t.factLinkText }}</a> {{ t.factAdditionalText }}
    </p>

    <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ t.listDate }} {{ header.contentDate }}</p>
    <p class="govuk-body">{{ t.listUpdated | replace("DATE", header.publishedDate) }} {{ header.publishedTime }}</p>

    {% if header.venueAddress | length %}
      <p class="govuk-body">
        {% for line in header.venueAddress %}
          {{ line }}{% if not loop.last %}<br>{% endif %}
        {% endfor %}
      </p>
    {% endif %}

    <div class="govuk-grid restriction-list-section govuk-!-margin-bottom-5">
      <div class="govuk-body">
        <h3>{{ t.restrictionInformationHeading }}</h3>
        <p class="govuk-body">{{ t.restrictionInformationP1 }}</p>
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            {{ t.restrictionInformationBoldText }}
          </strong>
        </div>
        <p class="govuk-body">{{ t.restrictionInformationP2 }}</p>
        <p class="govuk-body">{{ t.restrictionInformationP3 }}</p>
        <p class="govuk-body">{{ t.restrictionInformationP4 }}</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>{{ t.restrictionBulletPoint1 }}</li>
          <li>{{ t.restrictionBulletPoint2 }}</li>
        </ul>
      </div>
    </div>

    <div class="govuk-form-group govuk-!-margin-top-6">
      <h2 class="govuk-heading-m">{{ t.searchCases }}</h2>
      <input class="govuk-input govuk-!-width-one-half" id="case-search-input" name="search" type="text">
    </div>

    <div id="court-lists-container">
      <div class="govuk-accordion" data-module="govuk-accordion">
        {% for session in listData.sessions %}
          <div class="govuk-accordion__section govuk-accordion__section--expanded">
            <div class="govuk-accordion__section-header">
              <h2 class="govuk-accordion__section-heading">
                <span class="govuk-accordion__section-button">
                  {{ session.court }}
                </span>
              </h2>
            </div>
            <div class="govuk-accordion__section-content">
              <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ t.sittingAt }} {{ t.courtroom }} {{ session.room }}</p>
              <p class="govuk-body govuk-!-margin-bottom-1">{{ t.ljaLabel }}: {{ session.lja }}</p>
              <p class="govuk-body govuk-!-margin-bottom-4">{{ t.sessionStart }} {{ session.sessionStart }}</p>
              <div class="govuk-!-margin-bottom-4 overflow-table">
                <table class="govuk-table overflow-table" data-module="moj-sortable-table">
                  <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                      <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.blockStart }}</th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.defendantName }}</th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.dateOfBirth }}</th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.address }}</th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.age }}</th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.informant }}</th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.caseNumber }}</th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">{{ t.offenceCode }}</th>
                    </tr>
                  </thead>
                  <tbody class="govuk-table__body">
                    {% for case in session.cases %}
                      <tr class="govuk-table__row">
                        <td class="govuk-table__cell no-wrap no-border-bottom">{{ case.blockStart }}</td>
                        <td class="govuk-table__cell no-border-bottom">{{ case.defendantName }}</td>
                        <td class="govuk-table__cell no-wrap no-border-bottom">{{ case.dateOfBirth }}</td>
                        <td class="govuk-table__cell no-border-bottom">{{ case.address }}</td>
                        <td class="govuk-table__cell no-border-bottom">{{ case.age }}</td>
                        <td class="govuk-table__cell no-border-bottom">{{ case.informant }}</td>
                        <td class="govuk-table__cell no-border-bottom">{{ case.caseNumber }}</td>
                        <td class="govuk-table__cell no-border-bottom">{{ case.offenceCode }}</td>
                      </tr>
                      <tr class="govuk-table__row">
                        <td class="govuk-table__cell linked-cases-heading no-border-bottom no-right-border" colspan="2">{{ t.offenceTitle }}:</td>
                        <td class="govuk-table__cell no-border-bottom no-left-border" colspan="6">{{ case.offenceTitle }}</td>
                      </tr>
                      <tr class="govuk-table__row">
                        <td class="govuk-table__cell linked-cases-heading no-right-border" colspan="2">{{ t.offenceSummary }}:</td>
                        <td class="govuk-table__cell no-left-border" colspan="6">{{ case.offenceSummary }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <p class="govuk-body govuk-!-margin-top-6" style="font-size: 14px;">
      {{ t.dataSource }}: {{ dataSource }}
    </p>

  </div>
</div>
{% endblock %}
