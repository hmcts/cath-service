{% extends "layouts/base-template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tabs/macro.njk" import govukTabs %}

{% block pageTitle %}
  {{ title }} - {{ serviceName }} - {{ govUk }}
{% endblock %}

{% block page_content %}
<div class="parent-box">

  <style nonce="{{ cspNonce }}">
    .govuk-tabs__tab { font-weight: bold; }
  </style>

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <div class="govuk-button-group">
    {{ govukButton({
      text: addEmailSubscriptionButton,
      href: '/add-email-subscription'
    }) }}

    {{ govukButton({
      text: bulkUnsubscribeButton,
      href: '/bulk-unsubscribe' if count > 0,
      disabled: count == 0
    }) }}
  </div>

  {% if count > 0 %}
    {% set allTabHtml %}
      {% if hasCaseSubscriptions %}
        <table class="govuk-table" id="all-case-subscriptions-table" style="margin-bottom: 50px;">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ tableHeaderCaseName }}</th>
              <th scope="col" class="govuk-table__header">{{ tableHeaderReferenceNumber }}</th>
              <th scope="col" class="govuk-table__header" style="width: 160px;">{{ tableHeaderDate }}</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric" style="width: 100px;">{{ tableHeaderActions }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for subscription in caseSubscriptions %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell" style="vertical-align: middle;">{{ subscription.caseName }}</td>
                <td class="govuk-table__cell" style="vertical-align: middle;">{{ subscription.caseNumber }}</td>
                <td class="govuk-table__cell" style="white-space: nowrap; vertical-align: middle;">{{ subscription.dateAdded | date('D MMMM YYYY') }}</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  <form method="post" action="/delete-subscription" style="display: inline; margin: 0; padding: 0;">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="subscriptionId" value="{{ subscription.subscriptionId }}">
                    <button type="submit" class="govuk-link govuk-button-as-link" aria-label="Unsubscribe from {{ subscription.caseName }}">
                      {{ removeLink }}
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}

      {% if hasCourtSubscriptions %}
        {{ govukButton({ text: editListTypeLink, href: '/subscription-configure-list' }) }}
        <table class="govuk-table" id="all-court-subscriptions-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ tableHeaderLocation }}</th>
              <th scope="col" class="govuk-table__header" style="width: 160px;">{{ tableHeaderDate }}</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric" style="width: 100px;">{{ tableHeaderActions }}</th>
            </tr>
          </thead>

          <tbody class="govuk-table__body">
            {% for subscription in courtSubscriptions %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell" style="vertical-align: middle;">{{ subscription.courtOrTribunalName }}</td>
                <td class="govuk-table__cell" style="white-space: nowrap; vertical-align: middle;">{{ subscription.dateAdded | date('D MMMM YYYY') }}</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  <form method="post" action="/delete-subscription" style="display: inline; margin: 0; padding: 0;">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="subscriptionId" value="{{ subscription.subscriptionId }}">
                    <button type="submit" class="govuk-link govuk-button-as-link" aria-label="Unsubscribe from {{ subscription.courtOrTribunalName }}">
                      {{ removeLink }}
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
    {% endset %}

    {% set caseTabHtml %}
      {% if hasCaseSubscriptions %}
        <table class="govuk-table" id="case-subscriptions-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ tableHeaderCaseName }}</th>
              <th scope="col" class="govuk-table__header">{{ tableHeaderReferenceNumber }}</th>
              <th scope="col" class="govuk-table__header" style="width: 160px;">{{ tableHeaderDate }}</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric" style="width: 100px;">{{ tableHeaderActions }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for subscription in caseSubscriptions %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell" style="vertical-align: middle;">{{ subscription.caseName }}</td>
                <td class="govuk-table__cell" style="vertical-align: middle;">{{ subscription.caseNumber }}</td>
                <td class="govuk-table__cell" style="white-space: nowrap; vertical-align: middle;">{{ subscription.dateAdded | date('D MMMM YYYY') }}</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  <form method="post" action="/delete-subscription" style="display: inline; margin: 0; padding: 0;">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="subscriptionId" value="{{ subscription.subscriptionId }}">
                    <button type="submit" class="govuk-link govuk-button-as-link" aria-label="Unsubscribe from {{ subscription.caseName }}">
                      {{ removeLink }}
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="govuk-body">{{ noSubscriptionsInCategory }}</p>
      {% endif %}
    {% endset %}

    {% set courtTabHtml %}
      {% if hasCourtSubscriptions %}
        {{ govukButton({ text: editListTypeLink, href: '/subscription-configure-list' }) }}
        <table class="govuk-table" id="court-subscriptions-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ tableHeaderLocation }}</th>
              <th scope="col" class="govuk-table__header" style="width: 160px;">{{ tableHeaderDate }}</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric" style="width: 100px;">{{ tableHeaderActions }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for subscription in courtSubscriptions %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell" style="vertical-align: middle;">{{ subscription.courtOrTribunalName }}</td>
                <td class="govuk-table__cell" style="white-space: nowrap; vertical-align: middle;">{{ subscription.dateAdded | date('D MMMM YYYY') }}</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  <form method="post" action="/delete-subscription" style="display: inline; margin: 0; padding: 0;">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="subscriptionId" value="{{ subscription.subscriptionId }}">
                    <button type="submit" class="govuk-link govuk-button-as-link" aria-label="Unsubscribe from {{ subscription.courtOrTribunalName }}">
                      {{ removeLink }}
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="govuk-body">{{ noSubscriptionsInCategory }}</p>
      {% endif %}
    {% endset %}

    {{ govukTabs({
      items: [
        {
          label: tabAllSubscriptions + " (" + allSubscriptionsCount + ")",
          id: "all-subscriptions",
          panel: {
            html: allTabHtml
          }
        },
        {
          label: tabSubscriptionsByCase + " (" + caseSubscriptionsCount + ")",
          id: "case-subscriptions",
          panel: {
            html: caseTabHtml
          }
        },
        {
          label: tabSubscriptionsByCourt + " (" + courtSubscriptionsCount + ")",
          id: "court-subscriptions",
          panel: {
            html: courtTabHtml
          }
        }
      ]
    }) }}

  {% else %}
    <p class="govuk-body">{{ noSubscriptions }}</p>
  {% endif %}

</div>
{% endblock %}
