{% extends "layouts/base-template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% block pageTitle %}
  {% if errors %}Error: {% endif %}{{ title }} - {{ serviceName }} - {{ govUk }}
{% endblock %}

{% block backLink %}
  {{ govukBackLink({
    text: back,
    href: "/subscription-add-list-language"
  }) }}
{% endblock %}

{% block page_content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">

    <h1 class="govuk-heading-l">{{ heading }}</h1>

    {% if locationRows | length == 0 and confirmedCaseSubscriptions | length == 0 %}
      {{ govukErrorSummary({
        titleText: errors.titleText,
        errorList: errors.errorList
      }) }}
      <form action="/add-email-subscription" method="get">
        {{ govukButton({
          text: addSubscriptionsButton
        }) }}
      </form>
    {% elif locationRows | length == 0 %}

      <style nonce="{{ cspNonce }}">
        .govuk-table__cell, .govuk-table__header {
          padding-bottom: 0 !important;
        }
      </style>

      <table class="govuk-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ tableHeaderCaseName }}</th>
            <th scope="col" class="govuk-table__header">{{ tableHeaderReferenceNumber }}</th>
            <th scope="col" class="govuk-table__header govuk-!-text-align-right">{{ tableHeaderActions }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          {% for sub in confirmedCaseSubscriptions %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">{{ sub.caseName }}</td>
              <td class="govuk-table__cell">{{ sub.caseNumber }}</td>
              <td class="govuk-table__cell govuk-!-text-align-right">
                <form method="post" style="display: inline;">
                  <input type="hidden" name="action" value="remove-case-subscription">
                  <input type="hidden" name="caseIndex" value="{{ loop.index0 }}">
                  <button type="submit" class="govuk-link govuk-body" style="background: none; border: none; padding: 0; color: #1d70b8; text-decoration: underline; cursor: pointer;">
                    {{ removeLink }}
                  </button>
                </form>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <p class="govuk-body">
        <a href="/add-email-subscription" class="govuk-link">{{ addAnotherLink }}</a>
      </p>

      <form method="post" novalidate>
        <input type="hidden" name="action" value="confirm">
        {{ govukButton({
          text: confirmButton,
          type: "submit"
        }) }}
      </form>

    {% else %}

      {% if errors %}
        {{ govukErrorSummary({
          titleText: errors.titleText,
          errorList: errors.errorList
        }) }}
      {% endif %}

      <style nonce="{{ cspNonce }}">
        .govuk-table__cell, .govuk-table__header {
          padding-bottom: 0 !important;
        }
      </style>

      {% if confirmedCaseSubscriptions | length > 0 %}
        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ tableHeaderCaseName }}</th>
              <th scope="col" class="govuk-table__header">{{ tableHeaderReferenceNumber }}</th>
              <th scope="col" class="govuk-table__header govuk-!-text-align-right">{{ tableHeaderActions }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for sub in confirmedCaseSubscriptions %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ sub.caseName }}</td>
                <td class="govuk-table__cell">{{ sub.caseNumber }}</td>
                <td class="govuk-table__cell govuk-!-text-align-right">
                  <form method="post" style="display: inline;">
                    <input type="hidden" name="action" value="remove-case-subscription">
                    <input type="hidden" name="caseIndex" value="{{ loop.index0 }}">
                    <button type="submit" class="govuk-link govuk-body" style="background: none; border: none; padding: 0; color: #1d70b8; text-decoration: underline; cursor: pointer;">
                      {{ removeLink }}
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}

      <table class="govuk-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ tableHeaderCourt }}</th>
            <th scope="col" class="govuk-table__header govuk-!-text-align-right">{{ tableHeaderActions }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          {% for location in locationRows %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">{{ location.name }}</td>
              <td class="govuk-table__cell govuk-!-text-align-right">
                <form method="post" style="display: inline;">
                  <input type="hidden" name="action" value="remove-location">
                  <input type="hidden" name="locationId" value="{{ location.locationId }}">
                  <button type="submit" class="govuk-link govuk-body" style="background: none; border: none; padding: 0; color: #1d70b8; text-decoration: underline; cursor: pointer;">
                    {{ removeLink }}
                  </button>
                </form>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <table class="govuk-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ tableHeaderListType }}</th>
            <th scope="col" class="govuk-table__header govuk-!-text-align-right">{{ tableHeaderActions }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          {% for listType in listTypes %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">{{ listType.name }}</td>
              <td class="govuk-table__cell govuk-!-text-align-right">
                <form method="post" style="display: inline;">
                  <input type="hidden" name="action" value="remove-list-type">
                  <input type="hidden" name="listTypeId" value="{{ listType.listTypeId }}">
                  <button type="submit" class="govuk-link govuk-body" style="background: none; border: none; padding: 0; color: #1d70b8; text-decoration: underline; cursor: pointer;">
                    {{ removeLink }}
                  </button>
                </form>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <table class="govuk-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">
              {{ tableHeaderVersion }}
              <span title="{{ versionTooltip }}" aria-label="{{ versionTooltip }}" style="display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; border-radius: 50%; border: 2px solid #1d70b8; color: #1d70b8; font-size: 11px; font-weight: bold; cursor: default; margin-left: 4px; vertical-align: middle;">!</span>
            </th>
            <th scope="col" class="govuk-table__header govuk-!-text-align-right">{{ tableHeaderActions }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">{{ languageDisplay }}</td>
            <td class="govuk-table__cell govuk-!-text-align-right">
              <form method="post" style="display: inline;">
                <input type="hidden" name="action" value="change-version">
                <button type="submit" class="govuk-link govuk-body" style="background: none; border: none; padding: 0; color: #1d70b8; text-decoration: underline; cursor: pointer;">
                  {{ changeVersionLink }}
                </button>
              </form>
            </td>
          </tr>
        </tbody>
      </table>

      <p class="govuk-body">
        {% if listTypes | length == 0 %}
          <a id="select-list-types-link" href="/subscription-add-list" class="govuk-link">{{ selectListTypesLink }}</a>
        {% else %}
          <a href="/add-email-subscription" class="govuk-link">{{ addAnotherLink }}</a>
        {% endif %}
      </p>

      <form method="post" novalidate>
        <input type="hidden" name="action" value="confirm">
        {{ govukButton({
          text: confirmButton,
          type: "submit"
        }) }}
      </form>

    {% endif %}

  </div>
</div>
{% endblock %}
