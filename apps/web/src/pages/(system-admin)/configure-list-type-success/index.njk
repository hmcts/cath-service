{% extends "layouts/base-template.njk" %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}

{% block backLink %}
  {# No back link on success page #}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    {{ govukPanel({
      titleText: t.configureListType.success.title,
      html: t.configureListType.success.banner
    }) }}
  </div>
</div>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <h2 class="govuk-heading-m">{{ t.configureListType.success.description }}</h2>

    <ul class="govuk-list">
      <li><a href="/manage-list-types" class="govuk-link">{{ t.configureListType.success.manageListTypesLink }}</a></li>
      <li><a href="/system-admin-dashboard" class="govuk-link">{{ t.configureListType.success.returnLink }}</a></li>
    </ul>
  </div>
</div>
{% endblock %}
