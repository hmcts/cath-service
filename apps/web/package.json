{
  "name": "@hmcts/web",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -r \"yarn:dev:watch\" \"yarn:build:dev:watch\"",
    "dev:watch": "mkdir -p dist/assets; nodemon -w yarn.lock -w src -w ../../libs -e 'json,ts' -x 'tsx --env-file-if-exists=../../.env src/server.ts'",
    "dev:nowatch": "yarn build:dev && tsx --env-file-if-exists=../../.env src/server.ts",
    "build:dev:watch": "yarn build:dev --watch",
    "build:dev": "NODE_OPTIONS='--import tsx' vite build --config vite.build.ts",
    "build": "tsc --build && vite build --config vite.build.ts --configLoader runner",
    "clean": "rm -rf dist",
    "start": "node dist/server.js",
    "certs:generate": "../../scripts/generate-local-certs.sh",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@hmcts-cft/cloud-native-platform": "2.3.0",
    "@hmcts-cft/simple-router": "workspace:*",
    "@hmcts/admin-pages": "workspace:*",
    "@hmcts/administrative-court-daily-cause-list": "workspace:*",
    "@hmcts/ast-daily-hearing-list": "workspace:*",
    "@hmcts/auth": "workspace:*",
    "@hmcts/care-standards-tribunal-weekly-hearing-list": "workspace:*",
    "@hmcts/cic-weekly-hearing-list": "workspace:*",
    "@hmcts/civil-and-family-daily-cause-list": "workspace:*",
    "@hmcts/civil-daily-cause-list": "workspace:*",
    "@hmcts/cookie-manager": "1.1.0",
    "@hmcts/court-of-appeal-civil-daily-cause-list": "workspace:*",
    "@hmcts/family-daily-cause-list": "workspace:*",
    "@hmcts/list-types-common": "workspace:*",
    "@hmcts/location": "workspace:*",
    "@hmcts/london-administrative-court-daily-cause-list": "workspace:*",
    "@hmcts/magistrates-adult-court-list": "workspace:*",
    "@hmcts/magistrates-standard-list": "workspace:*",
    "@hmcts/public-pages": "workspace:*",
    "@hmcts/rcj-standard-daily-cause-list": "workspace:*",
    "@hmcts/send-daily-hearing-list": "workspace:*",
    "@hmcts/sjp-press-list": "workspace:*",
    "@hmcts/sjp-public-list": "workspace:*",
    "@hmcts/subscriptions": "workspace:*",
    "@hmcts/system-admin-pages": "workspace:*",
    "@hmcts/test-support": "workspace:*",
    "@hmcts/web-core": "workspace:*",
    "compression": "1.8.1",
    "config": "4.4.2",
    "connect-redis": "9.0.0",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "glob": "13.0.6",
    "govuk-frontend": "6.2.0",
    "helmet": "8.2.0",
    "multer": "2.1.1",
    "nunjucks": "3.2.4",
    "passport": "0.7.0",
    "pg": "8.21.0",
    "pg-format": "1.0.4",
    "redis": "5.12.1"
  },
  "devDependencies": {
    "@types/config": "4.4.0",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/govuk-frontend": "5.11.0",
    "@types/nunjucks": "3.2.6",
    "@types/supertest": "7.2.0",
    "concurrently": "10.0.3",
    "nodemon": "3.1.14",
    "sass": "1.101.0",
    "supertest": "7.2.2",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vite-plugin-static-copy": "3.4.0"
  }
}
