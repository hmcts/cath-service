{
  "name": "cath",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "e2e-tests",
    "libs/*",
    "libs/list-types/*"
  ],
  "scripts": {
    "postinstall": "yarn db:generate && node scripts/install-hooks.js",
    "test": "turbo test",
    "test:force": "turbo test --force",
    "test:coverage": "turbo test -- --coverage",
    "test:changed": "turbo test --filter='...[HEAD^1]'",
    "test:e2e": "yarn workspace e2e-tests run test:e2e",
    "format": "turbo format",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:fix:changed": "turbo lint:fix --filter='...[HEAD^1]'",
    "lint:changed": "turbo lint --filter='...[HEAD^1]'",
    "build": "turbo build",
    "build:force": "turbo build --force",
    "clean": "find . -name '*.tsbuildinfo' -delete && find apps libs -name 'dist' -type d -prune -exec rm -rf {} +",
    "start": "yarn dev:up && concurrently \"yarn:start:api\" \"yarn:start:web\"",
    "start:api": "NODE_ENV=production NODE_OPTIONS='--conditions=production' yarn workspace @hmcts/api run start",
    "start:web": "NODE_ENV=production NODE_OPTIONS='--conditions=production' yarn workspace @hmcts/web run start",
    "dev": "yarn dev:up && concurrently -n \"api,web\" \"yarn:dev:api\" \"yarn:dev:web\"",
    "dev:nowatch": "yarn dev:up && concurrently -n \"api,web\" \"yarn:dev:api\" \"yarn:dev:web:nowatch\"",
    "dev:ci": "concurrently -n \"api,web\" \"yarn:dev:api\" \"yarn:dev:web:nowatch\"",
    "dev:api": "yarn workspace @hmcts/api run dev",
    "dev:web": "yarn workspace @hmcts/web run dev",
    "dev:web:nowatch": "yarn workspace @hmcts/web run dev:nowatch",
    "dev:up": "docker compose up -d && yarn db:migrate:dev && yarn db:seed",
    "dev:down": "docker compose down",
    "db:migrate": "yarn workspace @hmcts/postgres run migrate",
    "db:seed": "tsx --env-file-if-exists=.env apps/postgres/prisma/seed.ts",
    "db:migrate:dev": "yarn workspace @hmcts/postgres run migrate:dev",
    "db:generate": "yarn workspace @hmcts/postgres-prisma run generate",
    "db:studio": "yarn workspace @hmcts/postgres run studio",
    "db:drop": "yarn workspace @hmcts/postgres run migrate:reset",
    "requirements:build": "requirements/scripts/init_db.sh"
  },
  "keywords": [],
  "author": "HMCTS",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@biomejs/cli-linux-arm64": "^2.3.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.10.4",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "concurrently": "10.0.3",
    "happy-dom": "^20.0.5",
    "lefthook": "2.1.9",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "packageManager": "yarn@4.17.0",
  "resolutions": {
    "@isaacs/brace-expansion": "5.0.1",
    "ajv": "8.20.0",
    "axios": "1.18.1",
    "body-parser": "2.3.0",
    "glob": "13.0.6",
    "jws": "4.0.1",
    "lodash": "4.18.1",
    "node-forge": "1.4.0",
    "pg": "8.21.0",
    "pg-connection-string": "2.14.0",
    "qs": "6.15.3",
    "tar": "7.5.19",
    "undici": "8.5.0",
    "vite": "8.1.4"
  },
  "dependencies": {
    "@azure/identity": "4.10.0",
    "@azure/storage-blob": "12.27.0",
    "@microsoft/microsoft-graph-client": "3.0.7",
    "@types/passport": "1.0.17",
    "accessible-autocomplete": "^3.0.1",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.1.0",
    "notifications-node-client": "^8.2.1",
    "openid-client": "6.8.4",
    "passport": "0.7.0",
    "pg": "8.21.0"
  }
}
