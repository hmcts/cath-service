{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_MCP_TOKEN}",
        "X-MCP-Toolsets": "issues,pull_requests,repos,projects",
        "X-MCP-Readonly": "true"
      }
    }
  }
}
