{
  "name": "@hmcts/excel-generation",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@hmcts/azure-blob": "workspace:*",
    "@hmcts/list-types-common": "workspace:*",
    "exceljs": "4.4.0"
  },
  "devDependencies": {
    "@types/node": "24.10.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
