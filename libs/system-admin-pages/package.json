{
  "name": "@hmcts/system-admin-pages",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./config": {
      "production": "./dist/config.js",
      "default": "./src/config.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe ."
  },
  "peerDependencies": {
    "express": "^5.2.0"
  },
  "dependencies": {
    "@hmcts/auth": "workspace:*",
    "@hmcts/list-search-config": "workspace:*",
    "@hmcts/list-types-common": "workspace:*",
    "@hmcts/location": "workspace:*",
    "@hmcts/postgres-prisma": "workspace:*",
    "@hmcts/publication": "workspace:*",
    "@hmcts/third-party-user": "workspace:*",
    "@hmcts/web-core": "workspace:*",
    "@launchdarkly/node-server-sdk": "^9.7.0",
    "papaparse": "5.5.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/multer": "^2.1.0",
    "@types/papaparse": "5.5.2",
    "typescript": "6.0.3"
  }
}
