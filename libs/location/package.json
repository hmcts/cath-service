{
  "name": "@hmcts/location",
  "version": "1.0.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./config": {
      "production": "./dist/config.js",
      "default": "./src/config.ts"
    },
    "./repository/queries": {
      "production": "./dist/repository/queries.js",
      "default": "./src/repository/queries.ts"
    },
    "./repository/service": {
      "production": "./dist/repository/service.js",
      "default": "./src/repository/service.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@hmcts/postgres-prisma": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": "*"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
