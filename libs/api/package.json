{
  "name": "@hmcts/blob-ingestion",
  "version": "1.0.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./middleware/oauth-middleware": {
      "production": "./dist/middleware/oauth-middleware.js",
      "default": "./src/middleware/oauth-middleware.ts"
    },
    "./repository/model": {
      "production": "./dist/blob-ingestion/repository/model.js",
      "default": "./src/blob-ingestion/repository/model.ts"
    },
    "./repository/service": {
      "production": "./dist/blob-ingestion/repository/service.js",
      "default": "./src/blob-ingestion/repository/service.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@hmcts/azure-blob": "workspace:*",
    "@hmcts/civil-and-family-daily-cause-list": "workspace:*",
    "@hmcts/list-types-common": "workspace:*",
    "@hmcts/location": "workspace:*",
    "@hmcts/pdda-html-upload": "workspace:*",
    "@hmcts/postgres-prisma": "workspace:*",
    "@hmcts/publication": "workspace:*",
    "@hmcts/system-admin-pages": "workspace:*",
    "multer": "1.4.5-lts.2"
  },
  "peerDependencies": {
    "express": "^5.2.0"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/multer": "1.4.13",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
