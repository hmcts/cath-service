<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ header.listTitle }}</title>
  <style>
    {{ pdfStyles | safe }}
    @page { size: A4 landscape; }
  </style>
</head>
<body>
  <div class="header-section">
    <h1>{{ header.listTitle }}</h1>

    <p><a href="{{ t.factLinkUrl }}">{{ t.factLinkText }}</a> {{ t.factAdditionalText }}</p>

    <p class="bold header-date">{{ t.listForDate }} {{ header.hearingDate }}</p>
    <p class="header-date">{{ t.lastUpdated }} {{ header.lastUpdatedDate }} {{ t.at }} {{ header.lastUpdatedTime }}</p>
  </div>

  <div class="opening-statement">
    <p>{{ t.openingStatement.detailsTitle }}</p>
    <p>{{ t.openingStatement.listChangeNotice }}</p>

    <p class="bold">{{ t.openingStatement.englandAndWalesTitle }}</p>
    <p>{{ t.openingStatement.englandAndWalesRemoteText }}</p>
    <p>{{ t.openingStatement.englandAndWalesCvpText }}</p>
    <p>{{ t.openingStatement.englandAndWalesAccessText }}</p>
    <p>{{ t.openingStatement.englandAndWalesContactText }}</p>

    <p class="bold">{{ t.openingStatement.scotlandTitle }}</p>
    <p>{{ t.openingStatement.scotlandRemoteText }}</p>
    <p>{{ t.openingStatement.scotlandCvpText }}</p>

    <p><a href="{{ t.openingStatement.observeLinkUrl }}">{{ t.openingStatement.observeLinkText }}</a></p>
  </div>

  {% if hearings.length > 0 %}
    <table>
      <thead>
        <tr>
          <th class="no-wrap">{{ t.tableHeaders.time }}</th>
          <th>{{ t.tableHeaders.appellant }}</th>
          <th>{{ t.tableHeaders.caseReferenceNumber }}</th>
          <th>{{ t.tableHeaders.judges }}</th>
          <th>{{ t.tableHeaders.members }}</th>
          <th>{{ t.tableHeaders.modeOfHearing }}</th>
          <th>{{ t.tableHeaders.venue }}</th>
          <th>{{ t.tableHeaders.additionalInformation }}</th>
        </tr>
      </thead>
      <tbody>
        {% for hearing in hearings %}
          <tr>
            <td class="no-wrap">{{ hearing.time }}</td>
            <td>{{ hearing.appellant }}</td>
            <td>{{ hearing.caseReferenceNumber }}</td>
            <td>{{ hearing.judges }}</td>
            <td>{{ hearing.members }}</td>
            <td>{{ hearing.modeOfHearing }}</td>
            <td>{{ hearing.venue }}</td>
            <td>{{ hearing.additionalInformation }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p>No hearings scheduled.</p>
  {% endif %}

  <div class="footer">
    {% if dataSource %}
    <p>{{ t.dataSource }}: {{ dataSource }}</p>
    {% endif %}
    <div class="caution-box">
      <p>{{ t.cautionNote }}</p>
      <p>{{ t.cautionReporting }}</p>
    </div>
  </div>
</body>
</html>
