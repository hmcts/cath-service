{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Upper Tribunal (Administrative Appeals Chamber) Daily Hearing List",
  "description": "Schema for Upper Tribunal (Administrative Appeals Chamber) Daily Hearing List",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["time", "caseReferenceNumber", "caseName"],
    "properties": {
      "time": {
        "title": "Time",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["10:00am"]
      },
      "appellant": {
        "title": "Appellant",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Smith"]
      },
      "caseReferenceNumber": {
        "title": "Case Reference Number",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["UTAAC/2025/0001"]
      },
      "caseName": {
        "title": "Case Name",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Smith v Secretary of State"]
      },
      "judges": {
        "title": "Judge(s)",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Judge Smith"]
      },
      "members": {
        "title": "Member(s)",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Member Jones"]
      },
      "modeOfHearing": {
        "title": "Mode of Hearing",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["CVP"]
      },
      "venue": {
        "title": "Venue",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Field House"]
      },
      "additionalInformation": {
        "title": "Additional Information",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Remote hearing"]
      }
    }
  }
}
