{
  "name": "@hmcts/sjp-press-list",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./config": {
      "production": "./dist/config.js",
      "default": "./src/config.ts"
    }
  },
  "scripts": {
    "build": "tsc && yarn build:schemas",
    "build:schemas": "mkdir -p dist/schemas && cp src/schemas/*.json dist/schemas/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@hmcts/list-types-common": "workspace:*",
    "@hmcts/pdf-generation": "workspace:*",
    "@hmcts/postgres-prisma": "workspace:*",
    "ajv": "8.20.0",
    "luxon": "3.7.2",
    "nunjucks": "3.2.4"
  },
  "devDependencies": {
    "@types/node": "24.10.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "express": "^5.1.0"
  }
}
