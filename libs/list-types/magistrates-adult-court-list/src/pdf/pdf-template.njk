<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ t.title }}</title>
  <style>{{ pdfStyles | safe }}</style>
  <style>
    .no-border-bottom {
      border-bottom: none;
    }
    .address {
      margin-top: 15px;
    }
    .address p {
      margin-bottom: 2px;
    }
    .warning-row {
      display: flex;
      align-items: flex-start;
      margin: 10px 0;
    }
    .warning-icon {
      display: inline-block;
      background-color: #0b0c0c;
      border-radius: 50%;
      color: #fff;
      font-size: 16px;
      font-weight: 700;
      height: 26px;
      line-height: 26px;
      margin-right: 10px;
      text-align: center;
      width: 26px;
      flex-shrink: 0;
    }
    .warning-text {
      font-weight: 700;
    }
    .no-border-bottom {
      border-bottom: none;
    }
    .linked-cases-heading {
      font-weight: bold;
    }
    .no-right-border {
      border-right: none;
    }
    .no-left-border {
      border-left: none;
    }
  </style>
</head>
<body>
  <div class="header-section">
    <h1>{{ t.pageTitle }} {{ header.locationName }}</h1>

    <p><a href="{{ t.factLinkUrl }}">{{ t.factLinkText }}</a> {{ t.factAdditionalText }}</p>

    <p class="bold header-date">{{ t.listDate }} {{ header.contentDate }}</p>
    <p class="header-date">{{ t.listUpdated | replace("DATE", header.publishedDate) }} {{ header.publishedTime }}</p>

    {% if header.venueAddress | length %}
      <div class="address">
        {% for line in header.venueAddress %}
          <p>{{ line }}</p>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="info-box">
    <h3>{{ t.restrictionInformationHeading }}</h3>
    <p>{{ t.restrictionInformationP1 }}</p>
    <div class="warning-row">
      <span class="warning-icon" aria-hidden="true">!</span>
      <span class="warning-text">{{ t.restrictionInformationBoldText }}</span>
    </div>
    <p>{{ t.restrictionInformationP2 }}</p>
    <p>{{ t.restrictionInformationP3 }}</p>
    <p>{{ t.restrictionInformationP4 }}</p>
    <ul>
      <li>{{ t.restrictionBulletPoint1 }}</li>
      <li>{{ t.restrictionBulletPoint2 }}</li>
    </ul>
  </div>

  {% for session in listData.sessions %}
    <div class="court-section">
      <h3>{{ session.court }}</h3>
      <p style="margin-bottom: 2px;"><strong>{{ t.sittingAt }} {{ t.courtroom }} {{ session.room }}</strong></p>
      <p style="margin-bottom: 2px;">{{ t.ljaLabel }}: {{ session.lja }}</p>
      <p style="margin-bottom: 10px;">{{ t.sessionStart }} {{ session.sessionStart }}</p>
      <table>
        <thead>
          <tr>
            <th>{{ t.blockStart }}</th>
            <th>{{ t.defendantName }}</th>
            <th>{{ t.dateOfBirth }}</th>
            <th>{{ t.address }}</th>
            <th>{{ t.age }}</th>
            <th>{{ t.informant }}</th>
            <th>{{ t.caseNumber }}</th>
            <th>{{ t.offenceCode }}</th>
          </tr>
        </thead>
        <tbody>
          {% for case in session.cases %}
            <tr>
              <td class="no-border-bottom">{{ case.blockStart }}</td>
              <td class="no-border-bottom">{{ case.defendantName }}</td>
              <td class="no-border-bottom">{{ case.dateOfBirth }}</td>
              <td class="no-border-bottom">{{ case.address }}</td>
              <td class="no-border-bottom">{{ case.age }}</td>
              <td class="no-border-bottom">{{ case.informant }}</td>
              <td class="no-border-bottom">{{ case.caseNumber }}</td>
              <td class="no-border-bottom">{{ case.offenceCode }}</td>
            </tr>
            <tr>
              <td class="linked-cases-heading no-border-bottom no-right-border" colspan="2">{{ t.offenceTitle }}:</td>
              <td class="no-border-bottom no-left-border" colspan="6">{{ case.offenceTitle }}</td>
            </tr>
            <tr>
              <td class="linked-cases-heading no-right-border" colspan="2">{{ t.offenceSummary }}:</td>
              <td class="no-left-border" colspan="6">{{ case.offenceSummary }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endfor %}

  <div class="footer">
    {% if dataSource %}
      <p>{{ t.dataSource }}: {{ dataSource }}</p>
    {% endif %}
  </div>
</body>
</html>
