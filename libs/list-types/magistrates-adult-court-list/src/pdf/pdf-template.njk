<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ t.title }}</title>
  <style>{{ pdfStyles | safe }}</style>
  <style>
    .no-border-bottom {
      border-bottom: none;
    }
    .address {
      margin-top: 15px;
    }
    .address p {
      margin-bottom: 2px;
    }
    .warning-row {
      display: flex;
      align-items: flex-start;
      margin: 10px 0;
    }
    .warning-icon {
      display: inline-block;
      background-color: #0b0c0c;
      border-radius: 50%;
      color: #fff;
      font-size: 16px;
      font-weight: 700;
      height: 26px;
      line-height: 26px;
      margin-right: 10px;
      text-align: center;
      width: 26px;
      flex-shrink: 0;
    }
    .warning-text {
      font-weight: 700;
    }
  </style>
</head>
<body>
  <div class="header-section">
    <h1>{{ t.header }} {{ header.locationName }}</h1>

    <p><a href="{{ t.factLinkUrl }}">{{ t.factLinkText }}</a> {{ t.factAdditionalText }}</p>

    <p class="bold header-date">{{ t.listDate }} {{ header.contentDate }}</p>
    <p class="header-date">{{ t.listUpdated | replace("DATE", header.publishedDate) }} {{ header.publishedTime }}</p>

    {% if header.venueAddress | length %}
      <div class="address">
        {% for line in header.venueAddress %}
          <p>{{ line }}</p>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="info-box">
    <h3>{{ t.restrictionInformationHeading }}</h3>
    <p>{{ t.restrictionInformationP1 }}</p>
    <div class="warning-row">
      <span class="warning-icon" aria-hidden="true">!</span>
      <span class="warning-text">{{ t.restrictionInformationBoldText }}</span>
    </div>
    <p>{{ t.restrictionInformationP2 }}</p>
    <p>{{ t.restrictionInformationP3 }}</p>
    <p>{{ t.restrictionInformationP4 }}</p>
    <ul>
      <li>{{ t.restrictionBulletPoint1 }}</li>
      <li>{{ t.restrictionBulletPoint2 }}</li>
    </ul>
  </div>

  {% for courtList in listData.courtLists %}
    {% set courtHouse = courtList.courtHouse %}
    <h2>{{ t.sittingAt }} {{ header.locationName }}</h2>
    {% for courtRoom in courtHouse.courtRoom %}
      {% for session in courtRoom.session %}
        <div class="court-section">
          <h3>
            {% if session.formattedJudiciaries | length %}
              {{ courtRoom.courtRoomName }}: {{ session.formattedJudiciaries }}
            {% else %}
              {{ courtRoom.courtRoomName }}
            {% endif %}
          </h3>
          <table>
            <thead>
              <tr>
                <th>{{ t.blockStart }}</th>
                <th>{{ t.defendantName }}</th>
                <th>{{ t.dateOfBirth }}</th>
                <th>{{ t.address }}</th>
                <th>{{ t.age }}</th>
                <th>{{ t.informant }}</th>
                <th>{{ t.caseNumber }}</th>
                <th>{{ t.offenceCode }}</th>
                <th>{{ t.offenceTitle }}</th>
                <th>{{ t.offenceSummary }}</th>
              </tr>
            </thead>
            <tbody>
              {% for sitting in session.sittings %}
                {% for hearing in sitting.hearing %}
                  {% for case in hearing.case %}
                    <tr>
                      <td>{{ case.blockStart }}</td>
                      <td>{{ case.defendantName }}</td>
                      <td>{{ case.dateOfBirth }}</td>
                      <td>{{ case.address }}</td>
                      <td>{{ case.age }}</td>
                      <td>{{ case.informant }}</td>
                      <td>{{ case.caseNumber }}</td>
                      <td>{{ case.offenceCode }}</td>
                      <td>{{ case.offenceTitle }}</td>
                      <td>{{ case.offenceSummary }}</td>
                    </tr>
                  {% endfor %}
                {% endfor %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endfor %}
    {% endfor %}
  {% endfor %}

  <div class="footer">
    {% if dataSource %}
      <p>{{ t.dataSource }}: {{ dataSource }}</p>
    {% endif %}
  </div>
</body>
</html>
