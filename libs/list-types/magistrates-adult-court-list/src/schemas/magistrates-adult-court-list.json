{
  "$defs": {
    "venueAddress": {
      "title": "Venue Address",
      "type": "object",
      "properties": {
        "line": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
          }
        },
        "town": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        },
        "county": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        },
        "postCode": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        }
      }
    },
    "judiciary": {
      "title": "Judiciary",
      "type": "object",
      "properties": {
        "johKnownAs": {
          "title": "JOH Known As",
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        }
      }
    },
    "individualDetails": {
      "title": "Individual Details",
      "type": "object",
      "properties": {
        "individualForenames": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        },
        "individualSurname": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        },
        "dateOfBirth": {
          "type": "string"
        },
        "age": {
          "type": "string"
        }
      }
    },
    "organisationDetails": {
      "title": "Organisation Details",
      "type": "object",
      "properties": {
        "organisationName": {
          "type": "string",
          "pattern": "^(?!.*(?:<\\s*\\/[^>]*>|<[^>]*\\/>|&lt;\\s*\\/[^&]*&gt;|&lt;[^&]*\\/&gt;)).*$"
        }
      }
    },
    "offence": {
      "title": "Offence",
      "type": "object",
      "properties": {
        "offenceTitle": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        }
      }
    },
    "party": {
      "title": "Party",
      "type": "object",
      "properties": {
        "partyRole": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        },
        "individualDetails": {
          "$ref": "#/$defs/individualDetails"
        },
        "organisationDetails": {
          "$ref": "#/$defs/organisationDetails"
        },
        "offence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/offence"
          }
        }
      }
    },
    "case": {
      "title": "Case",
      "type": "object",
      "properties": {
        "caseUrn": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        },
        "party": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/party"
          }
        },
        "reportingRestriction": {
          "type": "boolean"
        }
      }
    },
    "hearing": {
      "title": "Hearing",
      "type": "object",
      "properties": {
        "hearingType": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        },
        "case": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/case"
          }
        }
      }
    },
    "sitting": {
      "title": "Sitting",
      "type": "object",
      "properties": {
        "sittingStart": {
          "type": "string"
        },
        "hearing": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hearing"
          }
        }
      }
    },
    "session": {
      "title": "Session",
      "type": "object",
      "properties": {
        "judiciary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/judiciary"
          }
        },
        "sittings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sitting"
          }
        }
      }
    },
    "courtRoom": {
      "title": "Court Room",
      "type": "object",
      "properties": {
        "courtRoomName": {
          "type": "string",
          "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
        },
        "session": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/session"
          }
        }
      }
    },
    "courtList": {
      "title": "Court List",
      "type": "object",
      "required": ["courtHouse"],
      "properties": {
        "courtHouse": {
          "type": "object",
          "properties": {
            "courtHouseName": {
              "type": "string",
              "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$"
            },
            "courtRoom": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/courtRoom"
              }
            }
          }
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Magistrates Adult Court List",
  "type": "object",
  "required": ["document"],
  "properties": {
    "document": {
      "title": "Document",
      "type": "object",
      "properties": {
        "publicationDate": {
          "title": "Publication Date",
          "type": "string"
        }
      }
    },
    "venue": {
      "title": "Venue",
      "type": "object",
      "properties": {
        "venueAddress": {
          "$ref": "#/$defs/venueAddress"
        }
      }
    },
    "courtLists": {
      "title": "Court Lists",
      "type": "array",
      "items": {
        "$ref": "#/$defs/courtList"
      }
    }
  }
}
