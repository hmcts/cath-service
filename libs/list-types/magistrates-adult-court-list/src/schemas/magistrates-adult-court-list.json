{
  "$defs": {
    "address": {
      "title": "Address",
      "type": "object",
      "properties": {
        "line1": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "line2": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "line3": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "line4": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "line5": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "pcode": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" }
      }
    },
    "offence": {
      "title": "Offence",
      "type": "object",
      "properties": {
        "code": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "title": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "cy_title": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "sum": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "cy_sum": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" }
      }
    },
    "case": {
      "title": "Case",
      "type": "object",
      "properties": {
        "caseno": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "def_name": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "def_dob": { "type": "string" },
        "def_age": { "type": "number" },
        "def_addr": { "$ref": "#/$defs/address" },
        "inf": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "offences": {
          "type": "object",
          "properties": {
            "offence": {
              "type": "array",
              "items": { "$ref": "#/$defs/offence" }
            }
          }
        }
      }
    },
    "block": {
      "title": "Block",
      "type": "object",
      "properties": {
        "bstart": { "type": "string" },
        "cases": {
          "type": "object",
          "properties": {
            "case": {
              "type": "array",
              "items": { "$ref": "#/$defs/case" }
            }
          }
        }
      }
    },
    "session": {
      "title": "Session",
      "type": "object",
      "properties": {
        "lja": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "court": { "type": "string", "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$" },
        "room": { "type": "number" },
        "sstart": { "type": "string" },
        "blocks": {
          "type": "object",
          "properties": {
            "block": {
              "type": "array",
              "items": { "$ref": "#/$defs/block" }
            }
          }
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Magistrates Adult Court List",
  "type": "object",
  "required": ["document"],
  "properties": {
    "document": {
      "title": "Document",
      "type": "object",
      "properties": {
        "info": {
          "type": "object",
          "properties": {
            "start_time": { "type": "string" }
          }
        },
        "data": {
          "type": "object",
          "properties": {
            "job": {
              "type": "object",
              "properties": {
                "printdate": { "type": "string" },
                "sessions": {
                  "type": "object",
                  "properties": {
                    "session": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/session" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
