<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ t.title }}{% if header.regionName %}: {{ header.regionName }}{% endif %}</title>
  <style>{{ pdfStyles | safe }}</style>
</head>
<body>
  <div class="header-section">
    <h1>{{ t.title }}{% if header.regionName %}: {{ header.regionName }}{% endif %}</h1>

    <p><a href="{{ t.factLink }}">{{ t.factLinkText1 }}</a>{{ t.factLinkText2 }}</p>

    <div class="address">
      {% for line in header.addressLines %}
        {{ line }}{% if not loop.last %}<br>{% endif %}
      {% endfor %}
    </div>

    <p class="bold header-date">{{ t.listFor }} {{ header.contentDate }}</p>
    <p class="header-date">{{ t.lastUpdated }} {{ header.lastUpdated }}</p>
  </div>

  <div class="info-box">
    <h3>{{ t.importantInformation }}</h3>
    <p>{{ t.openJustice1 }}</p>
    <p>{{ t.openJustice2 }}</p>
    <p>{{ t.openJustice3 }}</p>
    <p>{{ t.openJustice4 }}</p>
    <p>{{ openJustice.venueName }}, {{ openJustice.email }}, {{ openJustice.phone }}</p>
    <p>{{ t.openJustice5 }}</p>
    <p>{{ t.openJustice6 }}</p>
  </div>

  {% for courtList in listData.courtLists %}
    {% set courtHouse = courtList.courtHouse %}
    <div class="court-section">
      <h2>{{ t.venue }} {{ courtHouse.courtHouseName }}</h2>
      {% if courtHouse.courtHouseAddress %}
        <div class="address">
          {% for line in courtHouse.courtHouseAddress.line %}
            {% if line | length %}{{ line }}<br>{% endif %}
          {% endfor %}
          {% if courtHouse.courtHouseAddress.town | length %}{{ courtHouse.courtHouseAddress.town }}<br>{% endif %}
          {% if courtHouse.courtHouseAddress.county | length %}{{ courtHouse.courtHouseAddress.county }}<br>{% endif %}
          {% if courtHouse.courtHouseAddress.postCode | length %}{{ courtHouse.courtHouseAddress.postCode }}{% endif %}
        </div>
      {% endif %}

      {% for courtRoom in courtHouse.courtRoom %}
        <div class="court-room-section">
          <div class="section-heading">{{ courtRoom.courtRoomName }}</div>

          <table>
            <thead>
              <tr>
                <th>{{ t.tableHeaders[0] }}</th>
                <th>{{ t.tableHeaders[1] }}</th>
                <th>{{ t.tableHeaders[2] }}</th>
                <th>{{ t.tableHeaders[3] }}</th>
                <th>{{ t.tableHeaders[4] }}</th>
                <th>{{ t.tableHeaders[5] }}</th>
                <th>{{ t.tableHeaders[6] }}</th>
              </tr>
            </thead>
            <tbody>
              {% for session in courtRoom.session %}
                {% for sitting in session.sittings %}
                  {% set durationText = '' %}
                  {% if sitting.durationAsHours > 0 %}
                    {% if sitting.durationAsHours > 1 %}
                      {% set durationText = sitting.durationAsHours ~ ' ' ~ t.hearingDurationHours %}
                    {% else %}
                      {% set durationText = sitting.durationAsHours ~ ' ' ~ t.hearingDurationHour %}
                    {% endif %}
                  {% endif %}
                  {% if sitting.durationAsMinutes > 0 %}
                    {% if durationText | length %}
                      {% set durationText = durationText ~ ' ' %}
                    {% endif %}
                    {% if sitting.durationAsMinutes > 1 %}
                      {% set durationText = durationText ~ sitting.durationAsMinutes ~ ' ' ~ t.hearingDurationMinutes %}
                    {% else %}
                      {% set durationText = durationText ~ sitting.durationAsMinutes ~ ' ' ~ t.hearingDurationMinute %}
                    {% endif %}
                  {% endif %}

                  {% for hearing in sitting.hearing %}
                    {% for case in hearing.case %}
                      <tr>
                        <td class="no-wrap">{{ sitting.time }}</td>
                        <td class="no-wrap">{{ durationText }}{% if case.caseSequenceIndicator %}{% if durationText | length %} {% endif %}[{{ case.caseSequenceIndicator }}]{% endif %}</td>
                        <td class="no-wrap">{{ case.caseNumber }}</td>
                        <td>{{ case.applicant }}</td>
                        <td>{{ case.respondent }}</td>
                        <td class="no-wrap">{{ hearing.hearingType }}</td>
                        <td class="no-wrap">{{ sitting.caseHearingChannel }}</td>
                      </tr>
                    {% endfor %}
                  {% endfor %}
                {% endfor %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endfor %}
    </div>
  {% endfor %}

  <div class="footer">
    {% if dataSource %}
    <p>{{ t.dataSource }}: {{ dataSource }}</p>
    {% endif %}
  </div>
</body>
</html>
