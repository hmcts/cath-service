<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ t.title }}</title>
  <style>{{ pdfStyles | safe }}</style>
</head>
<body>
  <div class="header-section">
    <h1>{{ t.inCop }}{% if header.region %}: {{ header.region }}{% endif %}</h1>
    {% if header.regionalJoh %}
      <h2>{{ t.regionalLeadJudge }} {{ header.regionalJoh }}</h2>
    {% endif %}
    <h2>{{ t.sittingAt }} {{ header.courtName }}</h2>

    <p class="bold header-date">{{ t.listFor }} {{ header.contentDate }}</p>

    <p><a href="{{ t.factLinkUrl }}">{{ t.factLinkText }}</a> {{ t.factAdditionalText }}</p>

    <p class="header-date">{{ t.lastUpdated }} {{ header.lastUpdated }}</p>
  </div>

  <div class="info-box">
    <h3>{{ t.importantInformation }}</h3>
    <p>{{ t.openJusticeIntro }}</p>
    <p>{{ t.openJusticeContact(openJustice.venueName, openJustice.email, openJustice.phone) }}</p>
    <p>{{ t.openJusticeDecision }}</p>
    <p>{{ t.openJusticePrivate }}</p>
    <p>{{ t.openJusticeMoreInfo }} <a href="{{ t.openJusticeLink }}">{{ t.openJusticeLinkText }}</a>.</p>
  </div>

  {% for courtList in listData.courtLists %}
    {% set courtHouse = courtList.courtHouse %}
    <div class="court-section">
      <h2>{{ courtHouse.courtHouseName }}</h2>

      {% for courtRoom in courtHouse.courtRoom %}
        {% for session in courtRoom.session %}
          <div class="court-room-section">
            <div class="section-heading">
              {% if session.formattedJudiciaries | length %}
                {{ courtRoom.courtRoomName }}, {{ t.beforeJudge }} {{ session.formattedJudiciaries }}
              {% else %}
                {{ courtRoom.courtRoomName }}
              {% endif %}
            </div>

            <table>
              <thead>
                <tr>
                  <th class="no-wrap">{{ t.startTime }}</th>
                  <th class="no-wrap">{{ t.caseRef }}</th>
                  <th class="no-wrap">{{ t.caseDetails }}</th>
                  <th class="no-wrap">{{ t.caseType }}</th>
                  <th class="no-wrap">{{ t.hearingType }}</th>
                  <th class="no-wrap">{{ t.timeEstimate }}</th>
                  <th class="no-wrap">{{ t.hearingChannel }}</th>
                </tr>
              </thead>
              <tbody>
                {% for sitting in session.sittings %}
                  {% set durationText = '' %}
                  {% if sitting.durationAsHours > 0 %}
                    {% if sitting.durationAsHours > 1 %}
                      {% set durationText = sitting.durationAsHours ~ ' hours' %}
                    {% else %}
                      {% set durationText = sitting.durationAsHours ~ ' hour' %}
                    {% endif %}
                  {% endif %}
                  {% if sitting.durationAsMinutes > 0 %}
                    {% if durationText | length %}
                      {% set durationText = durationText ~ ' ' %}
                    {% endif %}
                    {% if sitting.durationAsMinutes > 1 %}
                      {% set durationText = durationText ~ sitting.durationAsMinutes ~ ' mins' %}
                    {% else %}
                      {% set durationText = durationText ~ sitting.durationAsMinutes ~ ' min' %}
                    {% endif %}
                  {% endif %}

                  {% for hearing in sitting.hearing %}
                    {% for case in hearing.case %}
                      <tr>
                        <td class="no-wrap">{{ sitting.time }}</td>
                        <td class="no-wrap">{{ case.caseNumber }}</td>
                        <td>{{ case.caseName }}</td>
                        <td class="no-wrap">{{ case.caseType }}</td>
                        <td class="no-wrap">{{ hearing.hearingType }}</td>
                        <td class="no-wrap">{{ durationText }}{% if case.caseSequenceIndicator %} [{{ case.caseSequenceIndicator }}]{% endif %}</td>
                        <td class="no-wrap">{{ sitting.caseHearingChannel }}</td>
                      </tr>
                      {% if case.formattedReportingRestriction | length %}
                        <tr>
                          <td colspan="7"><strong>{{ t.reportingRestrictions }}:</strong> {{ case.formattedReportingRestriction }}</td>
                        </tr>
                      {% endif %}
                    {% endfor %}
                  {% endfor %}
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  {% endfor %}

  <div class="footer">
    {% if dataSource %}
    <p>{{ t.dataSource }}: {{ dataSource }}</p>
    {% endif %}
    <div class="caution-box">
      <p>{{ t.cautionNote }}</p>
      <p>{{ t.cautionReporting }}</p>
    </div>
  </div>
</body>
</html>
