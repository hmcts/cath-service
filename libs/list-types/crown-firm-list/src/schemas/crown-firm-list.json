{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Crown Firm PDDA List",
  "type": "object",
  "required": ["FirmList"],
  "properties": {
    "FirmList": {
      "type": "object",
      "required": ["DocumentID", "ListHeader", "CrownCourt", "CourtLists"],
      "properties": {
        "DocumentID": {
          "type": "string",
          "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$"
        },
        "ListHeader": {
          "type": "object",
          "properties": {
            "ListDate": { "type": "string" },
            "LastPublicationDate": { "type": "string" },
            "PublishedTime": { "type": "string" },
            "Version": { "type": "string" }
          }
        },
        "CrownCourt": {
          "type": "object",
          "required": ["CourtHouseName"],
          "properties": {
            "CourtHouseName": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
            "CourtHouseCode": { "type": "string" },
            "CourtHouseAddress": {
              "type": "object",
              "properties": {
                "CourtHouseAddressLine": { "type": "array", "items": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" } },
                "CourtHouseAddressTown": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                "CourtHouseAddressCounty": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                "CourtHouseAddressPostCode": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                "CourtHouseAddressPhone": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                "CourtHouseAddressEmail": { "type": "string" }
              }
            }
          }
        },
        "ReserveList": {
          "type": "array",
          "items": { "type": "object" }
        },
        "CourtLists": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["SittingDate", "Sittings"],
            "properties": {
              "SittingDate": { "type": "string" },
              "CourtHouse": {
                "type": "object",
                "properties": {
                  "CourtHouseName": { "type": "string" },
                  "CourtHouseCode": { "type": "string" }
                }
              },
              "Sittings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["CourtRoomNumber", "Judiciary"],
                  "properties": {
                    "CourtRoomNumber": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                    "SittingAt": { "type": "string" },
                    "Judiciary": {
                      "type": "object",
                      "required": ["Judge"],
                      "properties": {
                        "Judge": {
                          "type": "object",
                          "properties": {
                            "CitizenNameTitle": { "type": "string" },
                            "CitizenNameForename": { "type": "string" },
                            "CitizenNameSurname": { "type": "string" },
                            "CitizenNameRequestedName": { "type": "string" }
                          }
                        },
                        "Justice": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "CitizenNameTitle": { "type": "string" },
                              "CitizenNameForename": { "type": "string" },
                              "CitizenNameSurname": { "type": "string" }
                            }
                          }
                        }
                      }
                    },
                    "Hearings": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["HearingDetails", "CaseNumber"],
                        "properties": {
                          "HearingSequenceNumber": { "type": "string" },
                          "HearingDetails": {
                            "type": "object",
                            "properties": {
                              "HearingDescription": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                              "HearingType": { "type": "string" }
                            }
                          },
                          "CaseNumber": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                          "CaseNumberCaTH": { "type": "string" },
                          "CommittingCourt": { "type": "string" },
                          "ListNote": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                          "Prosecution": {
                            "type": "object",
                            "properties": {
                              "ProsecutingReference": { "type": "string" },
                              "ProsecutingOrganisation": { "type": "string" },
                              "ProsecutingAuthority": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" }
                            }
                          },
                          "Defendants": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "required": ["PersonalDetails"],
                              "properties": {
                                "PersonalDetails": {
                                  "type": "object",
                                  "required": ["Name", "IsMasked"],
                                  "properties": {
                                    "Name": {
                                      "type": "object",
                                      "properties": {
                                        "CitizenNameTitle": { "type": "string" },
                                        "CitizenNameForename": { "type": "string" },
                                        "CitizenNameSurname": { "type": "string" },
                                        "CitizenNameRequestedName": { "type": "string" }
                                      }
                                    },
                                    "MaskedName": { "type": "string" },
                                    "IsMasked": { "type": "string", "enum": ["yes", "no"] },
                                    "DateOfBirth": { "type": "string" },
                                    "Age": { "type": "number" },
                                    "Sex": { "type": "string" }
                                  }
                                },
                                "Counsel": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "Solicitor": {
                                        "type": "array",
                                        "items": {
                                          "type": "object",
                                          "properties": {
                                            "Party": {
                                              "type": "object",
                                              "properties": {
                                                "Person": {
                                                  "type": "object",
                                                  "properties": {
                                                    "CitizenNameForename": { "type": "string" },
                                                    "CitizenNameSurname": { "type": "string" }
                                                  }
                                                },
                                                "Organisation": {
                                                  "type": "object",
                                                  "properties": {
                                                    "OrganisationName": { "type": "string" }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                },
                                "URN": { "type": "string" },
                                "PrisonerID": { "type": "string" }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
