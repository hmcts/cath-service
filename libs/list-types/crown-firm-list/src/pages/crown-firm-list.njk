{% extends "layouts/base-template.njk" %}

{% block head %}
  {{ super() }}
  <style>
    .no-wrap {
      white-space: nowrap;
    }
    .govuk-accordion__section-content {
      overflow: auto hidden;
    }
    .govuk-table {
      overflow: auto hidden;
    }
  </style>
{% endblock %}

{% block page_content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">

    <h2 class="govuk-heading-l">{{ t.pageTitle }} {{ header.locationName }}</h2>

    <p class="govuk-body">
      {% for line in header.addressLines %}
        {{ line }}{% if not loop.last %}<br>{% endif %}
      {% endfor %}
    </p>

    <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ t.listFor }} {{ header.contentDate }}</p>
    <p class="govuk-body">{{ t.lastUpdated }} {{ header.lastUpdated }}</p>

    <div class="govuk-inset-text govuk-!-margin-top-6">
      <h2 class="govuk-heading-m">{{ t.reportingRestrictionsTitle }}</h2>
      <p class="govuk-body" style="white-space: pre-line;">{{ t.reportingRestrictionsBody }}</p>
    </div>

    <div id="court-lists-container">
      <div class="govuk-accordion" data-module="govuk-accordion">
        {% for dayGroup in groupedListData %}
          <div class="govuk-accordion__section govuk-accordion__section--expanded">
            <div class="govuk-accordion__section-header">
              <h2 class="govuk-accordion__section-heading">
                <span class="govuk-accordion__section-button">
                  {{ t.day }}: {{ dayGroup.day }}
                </span>
              </h2>
            </div>
            <div class="govuk-accordion__section-content">
              {% for sitting in dayGroup.sittings %}
                <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
                  {% if sitting.formattedJudiciaries | length %}
                    {{ sitting.courtRoomName }}, {{ t.beforeJudge }}: {{ sitting.formattedJudiciaries }}
                  {% else %}
                    {{ sitting.courtRoomName }}
                  {% endif %}
                </h3>
                <p class="govuk-body govuk-!-font-weight-bold">{{ t.sittingAt }} {{ sitting.time }}</p>
                <table class="govuk-table">
                  <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                      <th scope="col" class="govuk-table__header no-wrap">{{ t.caseNumber }}</th>
                      <th scope="col" class="govuk-table__header no-wrap">{{ t.defendant }}</th>
                      <th scope="col" class="govuk-table__header no-wrap">{{ t.hearingType }}</th>
                      <th scope="col" class="govuk-table__header no-wrap">{{ t.representative }}</th>
                      <th scope="col" class="govuk-table__header no-wrap">{{ t.prosecutingAuthority }}</th>
                      <th scope="col" class="govuk-table__header no-wrap">{{ t.listingNotes }}</th>
                    </tr>
                  </thead>
                  <tbody class="govuk-table__body">
                    {% for hearing in sitting.hearing %}
                      {% for case in hearing.case %}
                        <tr class="govuk-table__row">
                          <td class="govuk-table__cell no-wrap">{{ case.caseNumber }}</td>
                          <td class="govuk-table__cell">{{ case.defendants }}</td>
                          <td class="govuk-table__cell no-wrap">{{ hearing.displayHearingType }}</td>
                          <td class="govuk-table__cell">{{ case.representative }}</td>
                          <td class="govuk-table__cell no-wrap">{{ case.prosecutingAuthority }}</td>
                          <td class="govuk-table__cell">{{ case.listingNotes }}</td>
                        </tr>
                        {% if case.formattedReportingRestriction | length %}
                          <tr class="govuk-table__row">
                            <td class="govuk-table__cell" colspan="6">
                              <strong>{{ t.reportingRestrictions }}:</strong> {{ case.formattedReportingRestriction }}
                            </td>
                          </tr>
                        {% endif %}
                      {% endfor %}
                    {% endfor %}
                  </tbody>
                </table>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <p class="govuk-body-s govuk-!-margin-top-6">
      {{ t.dataSource }}: {{ dataSource }}
    </p>

  </div>
</div>
{% endblock %}
