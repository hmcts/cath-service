<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ t.pageTitle }} {{ header.locationName }}</title>
  <style>{{ pdfStyles | safe }}</style>
</head>
<body>
  <div class="header-section">
    <h1>{{ t.pageTitle }} {{ header.locationName }}</h1>

    <div class="address">
      {% for line in header.addressLines %}
        {{ line }}{% if not loop.last %}<br>{% endif %}
      {% endfor %}
    </div>

    <p class="bold header-date">{{ t.listFor }} {{ header.contentDate }}</p>
    <p class="header-date">{{ t.lastUpdated }} {{ header.lastUpdated }}</p>
  </div>

  <div class="info-box">
    <h3>{{ t.reportingRestrictionsTitle }}</h3>
    <p>{{ t.reportingRestrictionsBody }}</p>
  </div>

  {% for courtList in listData.courtLists %}
    {% set courtHouse = courtList.courtHouse %}
    <div class="court-section">
      {% if courtHouse.courtHouseAddress %}
        <h2>{{ courtHouse.courtHouseName }}</h2>
        <div class="address">
          {% for line in courtHouse.courtHouseAddress.line %}
            {% if line | length %}{{ line }}<br>{% endif %}
          {% endfor %}
          {% if courtHouse.courtHouseAddress.town | length %}{{ courtHouse.courtHouseAddress.town }}<br>{% endif %}
          {% if courtHouse.courtHouseAddress.county | length %}{{ courtHouse.courtHouseAddress.county }}<br>{% endif %}
          {% if courtHouse.courtHouseAddress.postCode | length %}{{ courtHouse.courtHouseAddress.postCode }}{% endif %}
        </div>
      {% endif %}

      {% for courtRoom in courtHouse.courtRoom %}
        {% for session in courtRoom.session %}
          {% for sitting in session.sittings %}
            <div class="court-room-section">
              <div class="section-heading">
                {{ t.day }}: {{ sitting.sittingDay }}
                {% if session.formattedJudiciaries | length %}
                  - {{ courtRoom.courtRoomName }}, {{ t.beforeJudge }}: {{ session.formattedJudiciaries }}
                {% else %}
                  - {{ courtRoom.courtRoomName }}
                {% endif %}
              </div>

              <p><strong>{{ t.sittingAt }} {{ sitting.time }}</strong></p>

              <table>
                <thead>
                  <tr>
                    <th class="no-wrap">{{ t.caseNumber }}</th>
                    <th class="no-wrap">{{ t.defendant }}</th>
                    <th class="no-wrap">{{ t.hearingType }}</th>
                    <th class="no-wrap">{{ t.representative }}</th>
                    <th class="no-wrap">{{ t.prosecutingAuthority }}</th>
                    <th class="no-wrap">{{ t.listingNotes }}</th>
                  </tr>
                </thead>
                <tbody>
                  {% for hearing in sitting.hearing %}
                    {% for case in hearing.case %}
                      <tr>
                        <td class="no-wrap">{{ case.caseNumber }}</td>
                        <td>{{ case.defendants }}</td>
                        <td class="no-wrap">{{ hearing.displayHearingType }}</td>
                        <td>{{ case.representative }}</td>
                        <td class="no-wrap">{{ case.prosecutingAuthority }}</td>
                        <td>{{ case.listingNotes }}</td>
                      </tr>
                      {% if case.formattedReportingRestriction | length %}
                        <tr class="restriction-row">
                          <td colspan="6">
                            <strong>{{ t.reportingRestrictions }}:</strong> {{ case.formattedReportingRestriction }}
                          </td>
                        </tr>
                      {% endif %}
                    {% endfor %}
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% endfor %}
        {% endfor %}
      {% endfor %}
    </div>
  {% endfor %}

  <div class="footer">
    {% if dataSource %}
    <p>{{ t.dataSource }}: {{ dataSource }}</p>
    {% endif %}
  </div>
</body>
</html>
