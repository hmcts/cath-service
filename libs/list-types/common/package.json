{
  "name": "@hmcts/list-types-common",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./config": {
      "production": "./dist/config.js",
      "default": "./src/config.ts"
    },
    "./src/assets/js/sjp-filter-search.js": {
      "production": "./dist/assets/js/sjp-filter-search.js",
      "default": "./src/assets/js/sjp-filter-search.ts"
    },
    "./src/assets/js/table-search.js": {
      "production": "./dist/assets/js/table-search.js",
      "default": "./src/assets/js/table-search.ts"
    },
    "./src/assets/css/*": {
      "production": "./dist/assets/css/*",
      "default": "./src/assets/css/*"
    }
  },
  "scripts": {
    "build": "tsc && yarn build:nunjucks",
    "build:nunjucks": "mkdir -p dist/views && cd src/views && find . -name '*.njk' -exec sh -c 'mkdir -p ../../dist/views/$(dirname {}) && cp {} ../../dist/views/{}' \\; || true",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@hmcts/azure-blob": "workspace:*",
    "@hmcts/location": "workspace:*",
    "@hmcts/pdf-generation": "workspace:*",
    "@hmcts/postgres-prisma": "workspace:*",
    "ajv": "8.20.0",
    "exceljs": "4.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.10.4",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
