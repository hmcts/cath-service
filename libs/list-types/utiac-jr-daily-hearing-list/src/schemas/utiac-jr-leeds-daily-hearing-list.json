{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UTIAC JR Leeds Daily Hearing List",
  "description": "Schema for Upper Tribunal (Immigration and Asylum) Chamber - Judicial Review: Leeds Daily Hearing List",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["venue", "judges", "hearingTime", "caseReferenceNumber", "caseTitle", "hearingType"],
    "properties": {
      "venue": {
        "title": "Venue",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Leeds Combined Court Centre"]
      },
      "judges": {
        "title": "Judge(s)",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Judge Smith"]
      },
      "hearingTime": {
        "title": "Hearing time",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["10:00am"]
      },
      "caseReferenceNumber": {
        "title": "Case reference number",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["JR/2025/003"]
      },
      "caseTitle": {
        "title": "Case title",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Smith v Secretary of State"]
      },
      "hearingType": {
        "title": "Hearing type",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Permission"]
      },
      "additionalInformation": {
        "title": "Additional information",
        "type": "string",
        "pattern": "^(?!(.|\\r|\\n)*<[^>]+>)(.|\\r|\\n)*$",
        "examples": ["Remote hearing"]
      }
    }
  }
}
