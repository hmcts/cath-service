{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Crown Warned PDDA List",
  "type": "object",
  "required": ["WarnedList"],
  "properties": {
    "WarnedList": {
      "type": "object",
      "required": ["DocumentID", "ListHeader", "CrownCourt", "CourtLists"],
      "properties": {
        "DocumentID": {
          "type": "string",
          "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$"
        },
        "ListHeader": {
          "type": "object",
          "properties": {
            "StartDate": { "type": "string" },
            "LastPublicationDate": { "type": "string" },
            "PublishedTime": { "type": "string" },
            "Version": { "type": "string" }
          }
        },
        "CrownCourt": {
          "type": "object",
          "required": ["CourtHouseName"],
          "properties": {
            "CourtHouseName": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
            "CourtHouseCode": { "type": "string" },
            "CourtHouseAddress": {
              "type": "object",
              "properties": {
                "CourtHouseAddressLine": { "type": "array", "items": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" } },
                "CourtHouseAddressTown": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                "CourtHouseAddressCounty": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                "CourtHouseAddressPostCode": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                "CourtHouseAddressPhone": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
                "CourtHouseAddressEmail": { "type": "string" }
              }
            }
          }
        },
        "CourtLists": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "CourtHouse": {
                "type": "object",
                "properties": {
                  "CourtHouseName": { "type": "string" },
                  "CourtHouseCode": { "type": "string" }
                }
              },
              "WithFixedDate": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "Fixture": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "FixedDate": { "type": "string" },
                          "Cases": {
                            "type": "array",
                            "items": { "$ref": "#/$defs/PddaCase" }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "WithoutFixedDate": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "Cases": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/PddaCase" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "CitizenName": {
      "type": "object",
      "properties": {
        "CitizenNameTitle": { "type": "string" },
        "CitizenNameForename": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
        "CitizenNameSurname": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
        "CitizenNameRequestedName": { "type": "string" }
      }
    },
    "PddaCase": {
      "type": "object",
      "properties": {
        "CaseNumber": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" },
        "Hearing": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ListNote": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" }
            }
          }
        },
        "Prosecution": {
          "type": "object",
          "properties": {
            "ProsecutingAuthority": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" }
          }
        },
        "Defendants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "PersonalDetails": {
                "type": "object",
                "properties": {
                  "Name": { "$ref": "#/$defs/CitizenName" },
                  "MaskedName": { "type": "string" },
                  "IsMasked": { "type": "string", "enum": ["yes", "no"] },
                  "CustodyStatus": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" }
                }
              }
            }
          }
        },
        "LinkedCases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "CaseNumber": { "type": "string", "pattern": "^(?!(.|\r|\n)*<[^>]+>)(.|\r|\n)*$" }
            }
          }
        },
        "CaseArrivedFrom": {
          "type": "object"
        }
      }
    }
  }
}
