{
  "name": "@hmcts/test-support",
  "version": "1.0.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./config": {
      "production": "./dist/config.js",
      "default": "./src/config.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@hmcts/azure-blob": "workspace:*",
    "@hmcts/postgres-prisma": "workspace:*",
    "cheerio": "1.2.0",
    "nunjucks": "3.2.4"
  },
  "peerDependencies": {
    "@prisma/client": "*",
    "express": "^5.2.0"
  },
  "devDependencies": {
    "@types/nunjucks": "3.2.6",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
