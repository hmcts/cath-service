{
  "name": "@hmcts/public-pages",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./config": {
      "production": "./dist/config.js",
      "default": "./src/config.ts"
    },
    "./flat-file/flat-file-service": {
      "production": "./dist/flat-file/flat-file-service.js",
      "default": "./src/flat-file/flat-file-service.ts"
    }
  },
  "scripts": {
    "build": "tsc --build && yarn build:routes",
    "build:routes": "mkdir -p dist/routes && cd src && find routes -name '*.ts' ! -name '*.test.ts' ! -name '*.spec.ts' -type f -exec sh -c 'mkdir -p ../dist/$(dirname {}) && cp {} ../dist/{}' \\; 2>/dev/null || true",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe ."
  },
  "peerDependencies": {
    "express": "^5.2.0"
  },
  "dependencies": {
    "@hmcts/location": "workspace:*",
    "@hmcts/postgres-prisma": "workspace:*",
    "@hmcts/publication": "workspace:*",
    "@hmcts/system-admin-pages": "workspace:*",
    "@hmcts/web-core": "workspace:*",
    "express-session": "^1.19.0"
  },
  "devDependencies": {
    "@types/express-session": "^1.19.0",
    "typescript": "6.0.3"
  }
}
