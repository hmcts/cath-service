{
  "name": "@hmcts/postgres-prisma",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate --no-hints && tsc",
    "dev": "concurrently -n tsc,prisma -r \"tsc --watch\" \"nodemon --watch prisma --ext prisma --exec 'prisma generate --no-hints && mkdir -p dist && touch dist/.prisma-generated'\"",
    "generate": "prisma generate --no-hints",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@prisma/client": "7.8.0"
  },
  "devDependencies": {
    "@types/node": "22.13.14",
    "nodemon": "3.1.14",
    "prisma": "7.8.0",
    "typescript": "5.8.3"
  }
}
