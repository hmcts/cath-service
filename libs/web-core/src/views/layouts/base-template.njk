{% extends "govuk/template.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% set govukRebrand = true %}

{% block head %}
  <link href="{{ web_css }}" rel="stylesheet">

  {% include "components/head-analytics.njk" %}
{% endblock %}

{% block bodyStart %}
  {% include "components/body-start-analytics.njk" %}
  {% include "components/cookie-banner.njk" %}
  <div class="app-watermark" aria-hidden="true">AI version</div>
{% endblock %}

{% block pageTitle %}
  {% include "components/page-title.njk" %}
{% endblock %}

{# Override the inner header blocks (not `header`) so govuk-frontend v6 still
   wraps them in the <header> landmark via its govuk-template__header element. #}
{% block govukHeader %}
  {% include "components/site-header.njk" %}
{% endblock %}

{% block govukServiceNavigation %}
  {% include "components/service-navigation.njk" %}
{% endblock %}

{% block beforeContent %}
  {% include "components/phase-banner-content.njk" %}
  {% block backLink %}
    {{ govukBackLink({
      text: back,
      href: "#"
    }) }}
  {% endblock %}
{% endblock %}

{% block content %}
  {% block error_summary %}
    {# Error summary would go here #}
  {% endblock %}

  {% block page_content %}
    {% if title %}
      <h1 class="govuk-heading-l">{{ title }}</h1>
    {% endif %}
  {% endblock %}
{% endblock %}

{# Override `govukFooter` (not `footer`) so govuk-frontend v6 still wraps it in
   the <footer> landmark via its govuk-template__footer element. #}
{% block govukFooter %}
  {% include "components/site-footer.njk" %}
{% endblock %}

{% block bodyEnd %}
  {% include "components/body-end-scripts.njk" %}
  <script nonce="{{ cspNonce }}">
    const backLink = document.getElementsByClassName("govuk-back-link").item(0);
    if (backLink) {
      backLink.addEventListener("click", function(event) {
        history.back();
        event.preventDefault();
      });
    }
  </script>
{% endblock %}