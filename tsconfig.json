{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types", "./types", "./libs/notifications/types"],
    "paths": {
      "@hmcts/api": ["apps/api/src"],
      "@hmcts/crons": ["apps/crons/src"],
      "@hmcts/postgres-prisma": ["libs/postgres-prisma/src"],
      "@hmcts/web": ["apps/web/src"],
      "@hmcts/web-core": ["libs/web-core/src"],
      "@hmcts/web-core/vite": ["libs/web-core/src/assets/vite-config"],
      "@hmcts/account": ["libs/account/src"],
      "@hmcts/account/repository/query": ["libs/account/src/repository/query"],
      "@hmcts/account/repository/service": ["libs/account/src/repository/service"],
      "@hmcts/admin-pages": ["libs/admin-pages/src"],
      "@hmcts/auth": ["libs/auth/src"],
      "@hmcts/cloud-native-platform": ["libs/cloud-native-platform/src"],
      "@hmcts/simple-router": ["libs/simple-router/src"],
      "@hmcts/verified-pages": ["libs/verified-pages/src"],
      "@hmcts/public-pages": ["libs/public-pages/src"],
      "@hmcts/public-pages/flat-file/flat-file-service": ["libs/public-pages/src/flat-file/flat-file-service.ts"],
