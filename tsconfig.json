      "@hmcts/rcj-standard-daily-cause-list": ["libs/list-types/rcj-standard-daily-cause-list/src"],
      "@hmcts/london-administrative-court-daily-cause-list": ["libs/list-types/london-administrative-court-daily-cause-list/src"],
      "@hmcts/court-of-appeal-civil-daily-cause-list": ["libs/list-types/court-of-appeal-civil-daily-cause-list/src"],
      "@hmcts/administrative-court-daily-cause-list": ["libs/list-types/administrative-court-daily-cause-list/src"],
      "@hmcts/blob-ingestion": ["libs/api/src"],
      "@hmcts/blob-ingestion/middleware/oauth-middleware": ["libs/api/src/middleware/oauth-middleware.ts"],
      "@hmcts/blob-ingestion/repository/model": ["libs/api/src/blob-ingestion/repository/model.ts"],
      "@hmcts/blob-ingestion/repository/service": ["libs/api/src/blob-ingestion/repository/service.ts"],
      "@hmcts/subscriptions": ["libs/subscriptions/src"],
      "@hmcts/sjp-press-list": ["libs/list-types/sjp-press-list/src"],
      "@hmcts/sjp-press-list/config": ["libs/list-types/sjp-press-list/src/config"],
      "@hmcts/sjp-public-list": ["libs/list-types/sjp-public-list/src"],
      "@hmcts/sjp-public-list/config": ["libs/list-types/sjp-public-list/src/config"],
      "@hmcts/subscriptions/config": ["libs/subscriptions/src/config"],
      "@hmcts/notification": ["libs/notification/src"],
      "@hmcts/notifications": ["libs/notifications/src"],
      "@hmcts/pdda-html-upload": ["libs/pdda-html-upload/src"],
      "@hmcts/list-search-config": ["libs/list-search-config/src"],
      "@hmcts/pdf-generation": ["libs/pdf-generation/src"],
      "@hmcts/legacy-third-party-fulfilment": ["libs/legacy-third-party-fulfilment/src"],
      "@hmcts/test-support": ["libs/test-support/src"],
      "@hmcts/test-support/config": ["libs/test-support/src/config"]
